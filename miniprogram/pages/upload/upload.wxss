/* pages/upload/upload.wxss */
.upload-page {
  min-height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
}

/* 顶部大图预览区 */
.preview-area {
  width: 100%;
  height: 500rpx;
  background: #FFFFFF;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #666;
}

.image-counter {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  color: #000;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* 缩略图栏 */
.thumbnail-bar {
  background: #fff;
  padding: 16rpx 24rpx;
  margin-top: 20rpx;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;  /* 未撑满时整体居中 */
  position: relative;
}

.thumbnail-scroll {
  white-space: nowrap;
  position: relative;
}

/* 撑满时：滚动区占满，按钮被挤到右边 */
.thumbnail-bar.overflow .thumbnail-scroll {
  flex: 1;
  width: 0;  /* 让 flex:1 生效 */
}

/* 超出时的羽化遮罩 */
.thumbnail-bar.overflow .thumbnail-scroll::before,
.thumbnail-bar.overflow .thumbnail-scroll::after {
  content: '';
  position: absolute;
  top: -16rpx;
  bottom: -16rpx;
  width: 50rpx;
  pointer-events: none;
  z-index: 10;
}

.thumbnail-bar.overflow .thumbnail-scroll::before {
  left: 0;
  background: linear-gradient(to right, #fff 0%, #fff 30%, transparent 100%);
}

.thumbnail-bar.overflow .thumbnail-scroll::after {
  right: 0;
  background: linear-gradient(to left, #fff 0%, #fff 30%, transparent 100%);
}

.thumbnail-list {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 1rpx;  /* 确保空列表也有宽度 */
}

/* 超出时靠左 */
.thumbnail-bar.overflow .thumbnail-list {
  justify-content: flex-start;
}

.thumbnail-item {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  border: 4rpx solid transparent;
  transition: border-color 0.2s;
}

.thumbnail-item.selected {
  border-color: #ff4d4f;
}

.thumbnail-image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  text-align: center;
  line-height: 32rpx;
}

.thumbnail-add {
  width: 80rpx;
  height: 80rpx;
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 无图时：按钮无左边距，居中显示 */
.thumbnail-add.no-margin {
  margin-left: 0;
}

.add-icon {
  font-size: 44rpx;
  color: #999;
}

/* 表单区域 */
.form-scroll {
  flex: 1;
  background: #fff;
}

.form-section {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.title-input {
  width: 100%;
  height: 65rpx;
  font-size: 32rpx;
  font-weight: 400;
  color: #333;
  background: transparent;
  letter-spacing: 2rpx;
}

.title-input.highlight {
  color: #ff4d4f;
}

.desc-input {
  width: 100%;
  height: 120rpx;
  font-size: 26rpx;
  color: #666;
  background: transparent;
}

.placeholder {
  color: #bbb;
}

/* 地点选择 */
.location-section {
  margin-top: 32rpx;
  border-top: 1rpx solid #eee;
  padding-top: 24rpx;
}

.location-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.location-label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.location-arrow {
  font-size: 32rpx;
  color: #999;
  transform: rotate(90deg);
  transition: transform 0.2s;
}

.location-arrow.expanded {
  transform: rotate(-90deg);
}

.location-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 16rpx;
}

.location-tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid transparent;
}

.location-tag.active {
  background: #fff2f0;
  color: #ff4d4f;
  border-color: #ff4d4f;
}

.custom-location-input {
  width: 160rpx;
  height: 56rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
}

/* 底部发布按钮 */
.submit-bar {
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

.submit-btn {
  height: 88rpx;
  background: #000;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  line-height: 88rpx;
}

.submit-btn.submitting {
  background: #ccc;
}
