# 本地开发：留空则使用 vite 代理 /api/admin -> CloudBase HTTP 路由
# VITE_ADMIN_API_URL=

# 生产构建（CloudBase 静态托管）必填：adminApi 完整 HTTP 地址
# 示例：https://your-env.ap-shanghai.app.tcloudbase.com/adminApi
VITE_ADMIN_API_URL=

# 可选：本地 dev 代理目标（见 vite.config.ts）
# VITE_CLOUDBASE_HTTP_BASE=https://your-env.ap-shanghai.app.tcloudbase.com
# VITE_ADMIN_API_PATH=/adminApi
