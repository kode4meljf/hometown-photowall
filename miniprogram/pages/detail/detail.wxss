/* pages/detail/detail.wxss */

/* 外层容器：flex纵向，撑满全屏 */
.detail-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F7F7F7;
  transition: opacity 0.15s ease;
}
.detail-shell.y-hidden {
  opacity: 0;
  pointer-events: none;
}

/* 顶部：固定高度 */
.header {
  flex-shrink: 0;
  background: #ffffff;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
  z-index: 100;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn text {
  font-size: 44rpx;
  color: #1b1b1b;
}

.author-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.author-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1b1b1b;
}

/* 可滚动区域 */
.detail-scroll {
  flex: 1;
  overflow-y: auto;
}

/* 图片区域：3:4 竖版，宽满屏，等比裁切居中 */
.image-section {
  width: 100%;
  height: calc(100vw * 4 / 3);
  background: #F7F7F7;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-swiper {
  width: 100%;
  height: 100%;
}

.photo-swiper .photo-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* ========== 全宽线段进度条（方案5：4px间距+圆角） ========== */
.progress-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 4px;
  padding: 0 4px;
  pointer-events: none;
}

.progress-segment {
  flex: 1;
  height: 3px;
  border-radius: 1.5px;
  transition: background 0.3s ease;
}

.progress-segment.done {
  background: rgba(255, 255, 255, 0.85);
}

.progress-segment.todo {
  background: rgba(255, 255, 255, 0.15);
}

/* 右上角文字指示器：滑动渐现 */
.photo-index-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: rgba(0, 0, 0, 0.45);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.photo-index-badge.badge-show {
  opacity: 1;
}

.badge-text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 500;
}

/* 内容区域 */
.content-section {
  padding: 24rpx;
  background: #ffffff;
}

.description {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.date {
  font-size: 26rpx;
  color: #999;
}

/* 分割线 */
.divider {
  height: 16rpx;
  background: #f8f8f8;
}

/* 评论数量 */
.comment-count {
  padding: 24rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #f0f0f0;
  background: #ffffff;
}

/* 评论列表 */
.comment-list {
  padding: 0 24rpx 24rpx;
  background: #ffffff;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.comment-author {
  font-size: 28rpx;
  font-weight: 500;
  color: #1b1b1b;
}

.comment-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

/* 加载更多动画 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #00ff99;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot1 { animation-delay: -0.32s; }
.dot2 { animation-delay: -0.16s; }
.dot3 { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.load-more-done {
  padding: 40rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #999;
}

/* ========== 底部操作栏（抖音图文详情页风格） ========== */
.bottom-bar {
  flex-shrink: 0;
  background: #ffffff;
  padding: 12rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
}

/* 输入框：带笔图标 */
.input-area {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 20rpx;
  background: #f4f4f4;
  border-radius: 44rpx;
}

.input-pen-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  opacity: 0.5;
}

.input-placeholder {
  font-size: 26rpx;
  color: #999;
}

/* 操作按钮组 */
.action-buttons {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  min-width: 72rpx;
  position: relative;
}

.action-icon-img {
  width: 52rpx;
  height: 52rpx;
  display: block;
}

/* 点赞时图标弹跳动画 */
.action-item.liked .action-icon-img {
  animation: likeBounce 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes likeBounce {
  0%   { transform: scale(1); }
  30%  { transform: scale(1.35); }
  60%  { transform: scale(0.9); }
  80%  { transform: scale(1.08); }
  100% { transform: scale(1); }
}

.action-num {
  font-size: 22rpx;
  color: #333;
  font-weight: 400;
  line-height: 1;
}

.action-num.liked {
  color: #fe2c55;  /* 点赞后数字变红 */
}

/* 评论输入弹窗 */
.comment-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.comment-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.comment-modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.comment-input-field {
  flex: 1;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.comment-send-btn {
  padding: 16rpx 32rpx;
  background: #00ff99;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #1b1b1b;
  font-weight: 500;
}

/* ========== 全屏预览层（FLIP动画 + 背景渐变） ========== */
.preview-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 9998;
  display: flex;
  flex-direction: column;
}

.preview-layer.bg-black {
  background: #121212;
}

.preview-layer.bg-transparent {
  background: transparent;
}

/* 下拉遮罩层：全屏覆盖，随下滑渐透明（自身透明，由 preview-layer 的 bg-black 提供底色） */
.preview-drag-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: transparent;
  pointer-events: none;
  z-index: 1;
  transition: opacity 0.05s linear;
}

/* 图片区域：透明占位，动画图片由 wrapper.position:fixed 覆盖 */
.preview-image-area {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

/* 动画容器：position: fixed 覆盖全屏，不依赖 flex 居中 */
/* 内部 image 用 object-fit: contain 自然居中，translateY 控制顶部位置 */
.preview-image-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  transform-origin: 0 0;
  will-change: transform;
  pointer-events: none;
}

/* FLIP 动画：弹簧曲线 cubic-bezier(0.34, 1.56, 0.64, 1)
   - 进入：350ms 弹簧，过冲 ~5% 后弹回
   - 退出：280ms 弹簧，更快更干脆 */
.preview-image-wrapper.animating-enter {
  transition: transform 350ms cubic-bezier(0.34, 1.56, 0.64, 1),
              opacity 80ms linear;
}

.preview-image-wrapper.animating-exit {
  transition: transform 280ms cubic-bezier(0.34, 1.56, 0.64, 1),
              opacity 80ms linear;
}

/* 非动画状态（手势/回弹）用普通缓动 */
.preview-image-wrapper.animating {
  transition: transform 300ms ease-out, opacity 80ms linear;
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.preview-swiper {
  width: 100%;
  height: 100%;
}

/* ========== 预览模式全宽线段进度条 ========== */
.preview-progress-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 4px;
  padding: 0 4px;
  pointer-events: none;
  z-index: 3;
}

.preview-progress-segment {
  flex: 1;
  height: 3px;
  border-radius: 1.5px;
  transition: background 0.3s ease;
}

.preview-progress-segment.done {
  background: rgba(255, 255, 255, 0.85);
}

.preview-progress-segment.todo {
  background: rgba(255, 255, 255, 0.15);
}

/* 预览模式右上角文字指示器 */
.preview-index-badge {
  position: absolute;
  top: 60rpx;
  right: 32rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
  z-index: 3;
}

.preview-index-badge.badge-show {
  opacity: 1;
}

.preview-badge-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
}

/* 点赞动画 */
.like-animation {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0);
  font-size: 120rpx;
  opacity: 0;
  pointer-events: none;
}

.like-animation.show {
  animation: likePop 0.6s ease-out forwards;
}

@keyframes likePop {
  0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
  30% { transform: translate(-50%, -50%) scale(1.3); opacity: 1; }
  60% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
}

/* ========== 底部固定黑色操作栏 ========== */
.preview-bottom-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  height: calc(84rpx + env(safe-area-inset-bottom));
  background: #000000;
}

/* 按钮容器透明度动画（进入全屏时配合 Step4 setData 触发） */
.preview-actions {
  position: relative;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.preview-actions.fade-in {
  opacity: 1;
}

.preview-action-item {
  position: absolute;
  top: 40%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
}

.preview-action-item:first-child {
  left: 64rpx;
}

.preview-action-item:last-child {
  right: 64rpx;
}

.preview-action-icon {
  font-size: 48rpx;
  color: #ffffff;
}

.preview-action-num {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 加载状态 */
.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  color: #999;
}
