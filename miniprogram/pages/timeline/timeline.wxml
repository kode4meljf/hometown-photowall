<!-- pages/timeline/timeline.wxml -->
<view class="timeline-page">
  <view class="timeline" wx:if="{{timeline.length > 0}}">
    <view class="timeline-item" wx:for="{{timeline}}" wx:key="year">
      <view class="year-marker">{{item.year}}</view>
      <view class="year-photos">
        <view 
          class="photo-card" 
          wx:for="{{item.photos}}" 
          wx:for-item="photo"
          wx:key="id"
          bindtap="goToDetail"
          data-id="{{photo.id}}"
        >
          <image class="photo-thumb" src="{{photo.imageUrl}}" mode="aspectFill" />
          <view class="photo-info">
            <text class="photo-title">{{photo.title}}</text>
            <text class="photo-date">{{photo.date}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && timeline.length === 0}}">
    <image class="empty-icon-image" src="/assets/icons/timeline-empty.png" mode="aspectFit" />
    <text class="empty-text">暂无时光记录</text>
  </view>

  <view class="loading" wx:if="{{loading && timeline.length === 0}}">
    <text>加载中...</text>
  </view>
</view>
