/* pages/profile/settings/security/security.wxss */

.security-page {
  min-height: 100vh;
  background: #f8f8f8;
}

.page-body {
  padding: 24rpx 0 120rpx;
}

.section-title {
  font-size: 26rpx;
  color: #bbb;
  padding: 24rpx 32rpx 16rpx;
  font-weight: 400;
}

/* 顶部账号卡片 */
.profile-card {
  margin: 0 16rpx 8rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.profile-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1b1b1b;
}

.profile-register-time {
  font-size: 24rpx;
  color: #999;
}

/* 列表卡片 */
.settings-card {
  margin: 0 16rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}

.row-border {
  border-bottom: 1rpx solid #f0f0f0;
}

.row-label {
  font-size: 30rpx;
  color: #1b1b1b;
}

.row-value {
  font-size: 28rpx;
  color: #1b1b1b;
}

.row-value-ok {
  color: #07c160;
}

.row-value-muted {
  color: #bbb;
}

.row-danger:active {
  background: #fafafa;
}

.row-danger-center {
  justify-content: center;
}

.row-danger-center .row-label-danger {
  flex: none;
  text-align: center;
}

.row-label-danger {
  color: #ff4444;
}

.row-arrow {
  font-size: 32rpx;
  color: #bbb;
  font-weight: 300;
}

/* 绑定区域 */
.bind-block {
  padding: 8rpx 32rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.bind-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.bind-hint-warn {
  color: #b8860b;
}

.bind-phone-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #1b1b1b;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.bind-phone-btn::after {
  border: none;
}

.bind-phone-btn-hover {
  opacity: 0.85;
}

.bind-phone-btn-secondary {
  background: #fff;
  color: #1b1b1b;
  border: 2rpx solid #1b1b1b;
}

/* 说明 */
.tip-box {
  margin: 16rpx 16rpx 0;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
}

.tip-box-danger {
  background: transparent;
  padding: 12rpx 32rpx 0;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}
