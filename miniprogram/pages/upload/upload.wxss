/* pages/upload/upload.wxss */
.upload-page {
  min-height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
}

/* 顶部大图预览区 */
.preview-area {
  width: calc(100% - 128rpx);
  margin: 0 auto 16rpx;
  aspect-ratio: 4 / 3;
  background: #fff;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* swiper 预览 */
.preview-swiper {
  width: 100%;
  height: 100%;
}

.preview-clip {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.preview-image {
  /* 宽高由 WXS inline style 动态计算，精确匹配照片渲染尺寸 */
}

.preview-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 0;
}

.preview-placeholder::after {
  border: none;
}

.preview-placeholder-active {
  opacity: 0.85;
}

.placeholder-icon {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 16rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #666;
}

/* 删除按钮：预览区右上角 */
.preview-delete-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.image-counter {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  color: #000;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* ─── 缩略图栏 ─── */
/* 缩略图栏：居中布局 */
.thumbnail-bar {
  padding: 16rpx 4rpx;
  display: flex;
  justify-content: center;
  overflow: hidden;
}
.thumbnail-bar.has-overflow {
  margin-left: 28rpx;
}

.thumbnail-wrapper {
  display: flex;
  align-items: center;
  max-width: 100%;
}

/* scroll-view：占满剩余空间，超出时水平滚动，NOT enable-flex（避免与父容器冲突） */
.thumbnail-scroll {
  flex: 0 1 auto; /* 不主动扩展，允许收缩，基础宽度由内容决定 */
  max-width: 100%;
  flex-direction: row;
  align-items: flex-start;
  display: flex;
  height: 88rpx;
  min-width: 0;
  white-space: nowrap;
}
/* 溢出时才加羽化遮罩，避免单图被遮挡 */
.thumbnail-scroll.has-overflow {
  -webkit-mask-image: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,1) 12rpx, rgba(255,255,255,1) calc(100% - 12rpx), rgba(255,255,255,0) 100%);
}
.thumbnail-scroll::-webkit-scrollbar {
  display: none;
}

/* 缩略图行 */
.thumbnail-row {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

/* 缩略图项 */
.thumbnail-item {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  border: 4rpx solid transparent;
  transition: border-color 0.2s;
}
.thumbnail-item.selected {
  border-color: #ff4d4f;
}
.thumbnail-image {
  width: 100%;
  height: 100%;
}

/* 添加按钮：固定在 bar 最右侧 */
.thumbnail-add {
  flex-shrink: 0;
  display: inline-flex;
  align-self: flex-start;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 16rpx;
  margin-left: 16rpx;
  transition: transform 0.15s ease, background 0.15s ease;
}

.thumbnail-add:active {
  transform: scale(0.94);
  background: #ffe0e0;
}

.add-icon {
  font-size: 44rpx;
  color: #999;
}

/* ─── 表单区域 ─── */
.form-scroll {
  flex: 1;
  background: #fff;
}

.form-section {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.title-input {
  width: 100%;
  height: 65rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  background: transparent;
  letter-spacing: 2rpx;
}

.title-input.highlight {
  color: #ff4d4f;
}

.desc-input {
  width: 100%;
  height: 120rpx;
  font-size: 28rpx;
  color: #666;
  background: transparent;
}

.placeholder {
  color: #bbb;
}

/* 地点选择 */
.location-section {
  margin-top: 32rpx;
  border-top: 1rpx solid #eee;
  padding-top: 24rpx;
}

.location-header {
  display: flex;
  align-items: center;
  padding: 10rpx 6rpx;
}

/* 选中后：整体白色背景（无圆角），文字替换为老根茶 */
.location-header.has-location {
  background: #ffffff;
  border-radius: 0;
}

.location-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  object-fit: contain;
  object-position: center;
  vertical-align: middle;
  flex-shrink: 0;
}

.location-label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* X 清除按钮：flex 自动撑到最右，纯白背景 */
.location-clear-btn {
  flex-shrink: 0;
  margin-left: auto;
  width: 36rpx;
  height: 36rpx;
  background: #ffffff;
  color: #999;
  font-size: 32rpx;
  text-align: center;
  line-height: 36rpx;
}

.location-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 16rpx;
  padding-left: 24rpx;
}

.location-tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid transparent;
}

.location-tag.active {
  background: #fff2f0;
  color: #ff4d4f;
  border-color: #ff4d4f;
}

.custom-location-input {
  width: 118rpx;
  height: 56rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  text-align: center;
}

/* 封面操作覆盖层 - 方案D：底部渐变遮罩 + 红色胶囊按钮 */
.cover-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 140rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 28rpx;
  z-index: 2;
}

.cover-btn-area {
  position: relative;
  z-index: 1;
  background: #ff4757;
  border-radius: 100px;
  padding: 0 24rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.cover-btn-area:active {
  transform: scale(0.94);
  opacity: 0.85;
}

.cover-btn-text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  line-height: 1;
}

.cover-current-area {
  position: relative;
  z-index: 1;
  background: rgba(255,255,255,0.25);
  border-radius: 100px;
  padding: 0 24rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-current-text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  line-height: 1;
}

/* 缩略图封面标签 */
.cover-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 71, 87, 0.85);
  text-align: center;
  padding: 2rpx 0;
  border-radius: 0 0 12rpx 12rpx;
}

.cover-tag-text {
  color: #fff;
  font-size: 18rpx;
  font-weight: 500;
}
.submit-bar {
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
}

.publish-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
  background: rgba(0, 0, 0, 0.4);
}

.publish-overlay-card {
  width: 82%;
  max-width: 520rpx;
  padding: 64rpx 48rpx 52rpx;
  background: #fff;
  border-radius: 40rpx;
  text-align: center;
  box-shadow: 0 40rpx 112rpx rgba(0, 0, 0, 0.2);
}

.publish-spinner {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 40rpx;
  border: 6rpx solid #eee;
  border-top-color: #333;
  border-radius: 50%;
  animation: publish-spin 0.85s linear infinite;
}

@keyframes publish-spin {
  to { transform: rotate(360deg); }
}

.publish-overlay-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 28rpx;
}

.publish-overlay-status {
  display: block;
  min-height: 44rpx;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 56rpx;
}

.publish-overlay-link {
  display: inline-flex;
  align-items: center;
  font-size: 28rpx;
  line-height: 1.5;
}

.publish-overlay-link-muted {
  color: #999;
}

.publish-overlay-link-em {
  color: #e8860a;
}

.publish-overlay-link:active .publish-overlay-link-em {
  opacity: 0.65;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #fff;
  color: #000;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.submit-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.submit-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 10rpx;
}

.submit-btn.submitting {
  background: #ccc;
  pointer-events: none;
}

.rejected-tip {
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  background: #fff8e8;
  border-radius: 12rpx;
}

.rejected-tip-text {
  font-size: 24rpx;
  color: #8a6a1a;
  line-height: 1.5;
}

.rejected-actions {
  display: flex;
  gap: 20rpx;
}

.reject-action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.reject-action-btn-danger {
  background: #fff;
  color: #e54d42;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.reject-action-btn-primary {
  background: #fff;
  color: #000;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);
}

.reject-action-btn-primary.submitting {
  background: #ccc;
  color: #666;
  pointer-events: none;
}

.reject-action-btn.disabled {
  opacity: 0.45;
  pointer-events: none;
}
