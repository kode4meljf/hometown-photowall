/* pages/upload/upload.wxss */
.upload-page {
  min-height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
}

/* 顶部大图预览区 */
.preview-area {
  width: 100%;
  height: 500rpx;
  background: #FFFFFF;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #666;
}

.image-counter {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  color: #000;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* 缩略图栏 */
.thumbnail-bar {
  background: #fff;
  margin-top: 20rpx;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  /* 无图时：scroll(收缩到内容宽) + button 整体居中 */
  justify-content: center;
  position: relative;
}

/* 有图时：scroll 占满左侧，按钮固定右侧 */
.thumbnail-bar.has-images {
  justify-content: space-between;
}

/* scroll-view */
.thumbnail-scroll {
  white-space: nowrap;
  min-height: 112rpx;
  padding: 16rpx 0;
}

/* 有图时：scroll 填满左侧剩余空间 */
.thumbnail-scroll.expand {
  flex: 1;
  min-width: 0;
}

/* 缩略图列表 */
.thumbnail-list {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  /* 关键：inline-flex + min-width:0 让列表收缩到内容宽度，不被 scroll-view 撑开 */
  min-width: 0;
}

/* 未溢出：列表内缩略图居中（按钮在列表最后一项，也居中） */
.thumbnail-list:not(.overflow) {
  justify-content: center;
}

/* 溢出：缩略图靠左，允许横向滚动 */
.thumbnail-list.overflow {
  justify-content: flex-start;
}

.thumbnail-item {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  border: 4rpx solid transparent;
  transition: border-color 0.2s;
}

.thumbnail-item.selected {
  border-color: #ff4d4f;
}

.thumbnail-image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  text-align: center;
  line-height: 32rpx;
}

.thumbnail-add {
  width: 80rpx;
  height: 80rpx;
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.thumbnail-add.disabled {
  opacity: 0.4;
}

.add-icon {
  font-size: 44rpx;
  color: #999;
}

/* 右侧羽化遮罩 */
.scroll-fade-right {
  position: absolute;
  top: 0;
  bottom: 0;
  right: 0;
  width: 60rpx;
  background: linear-gradient(to left, #fff 40%, transparent 100%);
  pointer-events: none;
}

/* 表单区域 */
.form-scroll {
  flex: 1;
  background: #fff;
}

.form-section {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.title-input {
  width: 100%;
  height: 65rpx;
  font-size: 32rpx;
  font-weight: 400;
  color: #333;
  background: transparent;
  letter-spacing: 2rpx;
}

.title-input.highlight {
  color: #ff4d4f;
}

.desc-input {
  width: 100%;
  height: 120rpx;
  font-size: 26rpx;
  color: #666;
  background: transparent;
}

.placeholder {
  color: #bbb;
}

/* 地点选择 */
.location-section {
  margin-top: 32rpx;
  border-top: 1rpx solid #eee;
  padding-top: 24rpx;
}

.location-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.location-label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.location-arrow {
  font-size: 32rpx;
  color: #999;
  transform: rotate(90deg);
  transition: transform 0.2s;
}

.location-arrow.expanded {
  transform: rotate(-90deg);
}

.location-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 16rpx;
}

.location-tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid transparent;
}

.location-tag.active {
  background: #fff2f0;
  color: #ff4d4f;
  border-color: #ff4d4f;
}

.custom-location-input {
  width: 160rpx;
  height: 56rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
}

/* 底部发布按钮 */
.submit-bar {
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

.submit-btn {
  height: 88rpx;
  background: #000;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  line-height: 88rpx;
}

.submit-btn.submitting {
  background: #ccc;
}
