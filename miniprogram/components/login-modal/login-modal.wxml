<view class="login-modal-overlay {{visible ? 'show' : ''}}" bindtap="onClose" catchtouchmove="preventTouchMove">
  <view class="login-modal-card" catchtap="preventTouchMove">

    <!-- 登录 -->
    <block wx:if="{{step === 'login'}}">
      <view class="login-modal-icon-wrap">
        <view class="login-modal-icon-inner">
          <image class="login-modal-icon-lg" src="/assets/icons/icon-wechat.svg" mode="aspectFit"/>
        </view>
      </view>
      <view class="login-modal-title">{{title}}</view>
      <view class="login-modal-desc" wx:if="{{subtitle}}">{{subtitle}}</view>
      <view class="login-modal-btn" bindtap="onWechatLogin" hover-class="login-modal-btn-hover">
        <view class="login-modal-btn-dot">
          <image class="login-modal-icon-sm" src="/assets/icons/icon-wechat.svg" mode="aspectFit"/>
        </view>
        <text class="login-modal-btn-text">{{loginText}}</text>
      </view>
      <view class="login-modal-cancel" bindtap="onClose">{{cancelText}}</view>
    </block>

    <!-- 新用户：选填昵称 -->
    <block wx:else>
      <view class="login-modal-title">设置昵称</view>
      <view class="login-modal-desc">选填，可使用微信昵称或自定义，稍后在「编辑资料」中修改</view>
      <view class="nickname-field">
        <input
          class="nickname-input"
          type="nickname"
          placeholder="点击输入昵称（选填）"
          value="{{nicknameDraft}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>
      <view class="login-modal-btn" bindtap="onConfirmNickname" hover-class="login-modal-btn-hover">
        <text class="login-modal-btn-text">完成</text>
      </view>
      <view class="login-modal-cancel" bindtap="onSkipNickname">跳过</view>
    </block>

  </view>
</view>
