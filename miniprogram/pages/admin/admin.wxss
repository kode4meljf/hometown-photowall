/* pages/admin/admin.wxss */
.admin-page {
  min-height: 100vh;
  background: #f8f8f8;
  padding-bottom: 40rpx;
}

.not-admin {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  text-align: center;
  padding: 40rpx;
}

.not-admin .icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.not-admin .text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.login-btn {
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #4CAF50, #66bb6a);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  font-size: 30rpx;
}

.admin-content {
  padding: 20rpx;
}

/* 统计卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.tab.active {
  background: #4CAF50;
  color: #ffffff;
}

.badge {
  margin-left: 8rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.3);
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}

.tab.active .badge {
  background: rgba(255, 255, 255, 0.3);
}

/* Section */
.section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.refresh-btn {
  font-size: 24rpx;
  color: #4CAF50;
  padding: 8rpx 16rpx;
  background: #e8f5e9;
  border-radius: 24rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

/* 照片列表 */
.photo-list {
  max-height: 800rpx;
  overflow-y: auto;
}

.photo-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.photo-item:last-child {
  border-bottom: none;
}

.photo-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.photo-info {
  flex: 1;
  min-width: 0;
}

.photo-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.photo-meta {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.photo-stats-row {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  color: #666;
}

.photo-actions {
  margin-left: 16rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #ff4444;
  padding: 12rpx 20rpx;
  background: #ffeaea;
  border-radius: 24rpx;
}

/* 用户列表 */
.user-list {
  max-height: 800rpx;
  overflow-y: auto;
}

.user-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.user-item:last-child {
  border-bottom: none;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #66bb6a);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.nickname {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.role-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.role-tag.admin {
  background: #fff3e0;
  color: #ff9800;
}

.role-tag.user {
  background: #e3f2fd;
  color: #2196f3;
}

.username {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.user-stats {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  color: #666;
}

.user-date {
  font-size: 22rpx;
  color: #bbb;
  flex-shrink: 0;
}

/* 退出登录 */
.logout-section {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.logout-btn {
  width: 100%;
  padding: 28rpx;
  background: #ffffff;
  color: #ff4444;
  border: 1rpx solid #ffcccc;
  border-radius: 16rpx;
  font-size: 30rpx;
}