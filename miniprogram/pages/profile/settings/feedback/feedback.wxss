.feedback-page {
  min-height: 100vh;
  background: #f8f8f8;
  padding: 24rpx;
}

.feedback-tip {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.feedback-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
  position: relative;
}

.feedback-textarea {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1b1b1b;
  box-sizing: border-box;
  line-height: 1.8;
  border: none;
  outline: none;
  caret-color: #1b1b1b;
}

.placeholder {
  color: #bbb;
}

.char-count {
  position: absolute;
  right: 16rpx;
  bottom: 12rpx;
  font-size: 22rpx;
  color: #bbb;
}

.feedback-input {
  width: 100%;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1b1b1b;
  box-sizing: border-box;
  border: none;
  outline: none;
  caret-color: #1b1b1b;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #1b1b1b;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  margin-top: 16rpx;
  text-align: center;
  border: none;
  padding: 0;
}

.submit-btn:active {
  opacity: 0.8;
}
