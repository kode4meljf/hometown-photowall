.doc-page {
  min-height: 100vh;
  background: #f8f8f8;
}

.page-body {
  padding: 24rpx;
}

.doc-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
}

.doc-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1b1b1b;
  text-align: center;
  margin-bottom: 32rpx;
}

.doc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 2;
}
