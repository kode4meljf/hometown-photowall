# 本地开发：留空则使用 vite 代理 /api/admin -> CloudBase HTTP 路由
# VITE_ADMIN_API_URL=

# 生产构建（CloudBase 静态托管）必填：adminApi 完整 HTTP 地址
# 注意：不要用 .service.tcloudbase.com 根路径打开浏览器，根路径无页面会 404
VITE_ADMIN_API_URL=https://hometown-photos-d4fm4k2ca299019d.service.tcloudbase.com/adminApi

# 管理后台页面（静态托管，浏览器打开这个）：
# https://hometown-photos-d4fm4k2ca299019d-1419842609.tcloudbaseapp.com

# 可选：本地 dev 代理目标（见 vite.config.ts）
# VITE_CLOUDBASE_HTTP_BASE=https://hometown-photos-d4fm4k2ca299019d.service.tcloudbase.com
# VITE_ADMIN_API_PATH=/adminApi
