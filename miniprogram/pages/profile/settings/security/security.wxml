<view class="security-page">
  <view class="page-body">

    <!-- 账号概览 -->
    <view class="profile-card">
      <image class="profile-avatar" src="{{avatar}}" mode="aspectFill" />
      <view class="profile-meta">
        <text class="profile-name">{{nickname}}</text>
        <text class="profile-register-time">注册于 {{registerTime}}</text>
      </view>
    </view>

    <!-- 登录与绑定 -->
    <view class="section-title">登录与绑定</view>
    <view class="settings-card">
      <view class="row row-border">
        <text class="row-label">微信</text>
        <text class="row-value row-value-ok">已登录</text>
      </view>
      <view class="row">
        <text class="row-label">手机号</text>
        <text class="row-value {{hasPhone ? '' : 'row-value-muted'}}">{{hasPhone ? phoneDisplay : '未绑定'}}</text>
      </view>
      <view class="bind-block" wx:if="{{!hasPhone}}">
        <text class="bind-hint bind-hint-warn">个人主体小程序无法使用微信「一键获取手机号」，需升级为企业主体并开通「手机号快速验证」后才可绑定。</text>
        <text class="bind-hint">换微信号后请尽量使用原微信登录；作品与账号 UID 绑定，注销或删号会导致无法找回。</text>
      </view>
    </view>

    <view class="tip-box" wx:if="{{hasPhone}}">
      <text class="tip-text">已绑定手机号时，换微信号可在登录页使用「手机号找回」。个人主体暂不支持新绑定。</text>
    </view>

    <!-- 危险操作 -->
    <view class="section-title">危险操作</view>
    <view class="settings-card">
      <view class="row row-danger row-danger-center" bindtap="onDeleteAccount">
        <text class="row-label row-label-danger">注销账号</text>
      </view>
    </view>
    <view class="tip-box tip-box-danger">
      <text class="tip-text">注销后将删除账号及全部作品，且不可恢复。</text>
    </view>

  </view>
</view>
