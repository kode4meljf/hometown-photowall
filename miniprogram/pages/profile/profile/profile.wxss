/* pages/profile/profile.wxss */
.profile-page {
  min-height: 100vh;
  background: #f8f8f8;
  padding-top: 24rpx;
  padding-bottom: 120rpx;
}

/* 用户头部 - 白色卡片，下方两角圆角衔接 func-section */
.user-header {
  background: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx 20rpx 0 0;
  padding: 40rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头像 - 圆形居中 */
.avatar {
  width: 120rpx !important;
  height: 120rpx !important;
  border-radius: 50% !important;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex: none;
  padding: 0;
  margin: 0 0 16rpx;
  border: none;
  line-height: normal;
  box-sizing: border-box;
}
.avatar::after { display: none; }
.avatar-center { align-self: center; }
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: inherit;
  display: block;
  flex-shrink: 0;
}

/* 昵称 */
.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #1b1b1b;
  text-align: center;
  margin-bottom: 8rpx;
}

/* 副标题 */
.profile-subtitle {
  font-size: 24rpx;
  color: #aaa;
  text-align: center;
  margin-bottom: 4rpx;
}

/* 地区+性别标签组 - 分开显示 */
.profile-region-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

/* 单个标签 */
.profile-region-tag {
  font-size: 22rpx;
  color: #888;
  line-height: 1;
  background: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 性别标签（与地区标签共用 .profile-region-tag） */
.gender-tag {
  display: inline;
}

/* bio + 标签区块（方案C极简） */
.profile-bio-tags {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
  padding: 0 16rpx;
}

.profile-bio {
  font-size: 24rpx;
  color: #888;
  text-align: center;
  line-height: 1.5;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
}

.profile-tag {
  font-size: 20rpx;
  color: #666;
  background: #f0f0f0;
  padding: 5rpx 14rpx;
  border-radius: 16rpx;
}

.profile-tag-first {
  background: #1b1b1b;
  color: #fff;
}

/* 三栏统计 */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 28rpx;
  width: 100%;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #1b1b1b;
}
.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 操作按钮 */
.action-btns {
  display: flex;
  gap: 16rpx;
  width: 100%;
  justify-content: center;
}
.action-btn {
  flex: 1;
  max-width: 340rpx;
  padding: 18rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: 1rpx solid #e0e0e0;
  color: #1b1b1b;
  background: #fff;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.action-btn:active {
  transform: scale(0.94);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.action-btn-primary {
  background: #1b1b1b;
  color: #fff;
  border-color: transparent;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.action-btn-primary:active {
  transform: scale(0.94);
  background: #333;
}
.action-btn-press {
  opacity: 0.5;
}

/* 常用功能3宫格 */
.func-section {
  background: #ffffff;
  margin: 0;
  border-radius: 0 0 16px 16px;
  padding: 72rpx 24rpx 48rpx;
}
.section-label {
  font-size: 26rpx;
  color: #bbbbbb;
  font-weight: 500;
  letter-spacing: 1rpx;
  margin-bottom: 42rpx;
}
.func-row {
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
}
.func-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.func-item-press {
  opacity: 0.5;
}
.func-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.func-icon image {
  width: 44rpx;
  height: 44rpx;
  object-fit: contain;
}
.func-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #1b1b1b;
}

/* 标签切换 */
.tabs-container {
  background: #f8f8f8;
  padding: 0 24rpx;
}

.tabs {
  display: flex;
  height: 80rpx;
  gap: 48rpx;
}

.tab {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 30rpx;
  color: #999999;
  flex-shrink: 0;
}

.tab.active {
  color: #1b1b1b;
  font-weight: 600;
}

.tab .count {
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  background: #e8e8e8;
  border-radius: 20rpx;
  color: #999999;
  font-weight: normal;
}

.tab.active .count {
  background: #1b1b1b;
  color: #ffffff;
}

/* 内容区域 */
.content-swiper {
  height: calc(100vh - 360rpx);
  background: #f8f8f8;
}

.swiper-item {
  height: 100%;
}

.photo-scroll {
  height: 100%;
  padding: 8rpx;
  box-sizing: border-box;
}

.photo-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4rpx;
  padding: 8rpx;
}
.photo-card {
  aspect-ratio: 3 / 4;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  background: #ffffff;
}

.photo-status-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  z-index: 2;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  line-height: 1.2;
  color: #fff;
}

.photo-status-badge--reviewing {
  background: rgba(245, 158, 11, 0.92);
}

.photo-status-badge--rejected {
  background: rgba(224, 32, 32, 0.88);
}

.photo-image {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  color: #ffffff;
}

.photo-title {
  font-size: 22rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.photo-stats {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.9;
}

/* 右上角操作按钮 */
.photo-more-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  z-index: 10;
  line-height: 1;
}

/* 删除选项红色 */
.modal-option-danger {
  color: #e02020;
}

.modal-option-muted {
  color: #999;
}

.modal-status-tip {
  padding: 28rpx 32rpx 8rpx;
  text-align: center;
}

.modal-status-tip-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.5;
  color: #666;
}

.modal-rules-link {
  display: inline-block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #576b95;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon-image {
  width: 120rpx;
  height: 180rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-text-dark {
  color: #1b1b1b;
  font-weight: 500;
}

.empty-btn {
  padding: 24rpx 48rpx;
  background: #1b1b1b;
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 底部弹窗 - 微信原生 ActionSheet 风格 */
.avatar-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}

.avatar-modal-content {
  width: 100%;
  background: transparent;
  padding: 0 16rpx;
  box-sizing: border-box;
}

/* 选项组容器 - 只有上圆角，底部贴紧取消按钮 */
.modal-options-group {
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  margin-bottom: 0;
}

.modal-option {
  text-align: center;
  padding: 30rpx 0;
  font-size: 34rpx;
  color: #1b1b1b;
  font-weight: 400;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
}

.modal-option:first-child {
  border-top: none;
}

/* 取消按钮 - 与选项组同一卡片，浅色分割线与「删除」区分 */
.modal-cancel {
  text-align: center;
  font-size: 34rpx;
  color: #1b1b1b;
  padding: 30rpx 0 calc(30rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 0 0 24rpx 24rpx;
  border-top: 1rpx solid #f2f2f2;
  font-weight: 500;
  margin-top: 0;
}

/* 危险选项（删除）红色文字 */
.modal-option-danger {
  color: #e02020;
}

/* 编辑作品弹窗 */
.edit-post-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.edit-post-panel {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 32rpx;
  box-sizing: border-box;
}

.edit-post-heading {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1b1b1b;
  margin-bottom: 24rpx;
}

.edit-post-tip {
  background: #fff8e6;
  color: #b8860b;
  font-size: 24rpx;
  line-height: 1.5;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.edit-post-field {
  margin-bottom: 24rpx;
}

.edit-post-label {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.edit-post-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #f7f7f7;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #1b1b1b;
}

.edit-post-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f7f7f7;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #1b1b1b;
  line-height: 1.5;
}

.edit-post-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.edit-post-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.edit-post-btn-cancel {
  background: #f2f2f2;
  color: #666;
}

.edit-post-btn-save {
  background: #07c160;
  color: #fff;
  font-weight: 500;
}

.edit-post-btn-disabled {
  opacity: 0.45;
  pointer-events: none;
}

/* ── 作品下拉筛选弹窗（fixed 定位，防止被 swiper overflow 截断） ── */

/* 遮罩层：透明全屏，点击关闭弹窗 */
.works-dropdown-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 990;
  background: transparent;
}

/* 弹窗外层：JS 动态计算位置，水平居中在 Tab 正下方 */
.works-dropdown-wrap {
  position: fixed;
  z-index: 991;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

/* 下拉弹窗（纯白） */
.works-dropdown {
  width: 300rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.12);
  overflow: hidden;
}

/* 小三角：在弹窗外上方，箭头向上指向 Tab 中心 */
.dropdown-arrow {
  position: absolute;
  top: -20rpx;
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 20rpx solid #fff;
  z-index: 1;
  filter: drop-shadow(0 -2rpx 3rpx rgba(0, 0, 0, 0.1));
}

/* 筛选选项 */
.dropdown-item {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx;
  transition: background 0.15s;
}

.dropdown-item:not(:last-child) {
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* 左侧小红点 */
.dropdown-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: transparent;
  flex-shrink: 0;
  margin-right: 14rpx;
  transition: background 0.15s;
}

.dropdown-item.active .dropdown-dot {
  background: #ff5a5f;
}

/* 选项文字 */
.dropdown-label {
  font-size: 26rpx;
  color: #444444;
  flex: 1;
  transition: color 0.15s;
}

.dropdown-item.active .dropdown-label {
  color: #ff5a5f;
  font-weight: 600;
}

/* 数量标签 */
.dropdown-count {
  font-size: 20rpx;
  color: #999;
  background: #f2f2f2;
  padding: 3rpx 12rpx;
  border-radius: 16rpx;
  transition: background 0.15s, color 0.15s;
  min-width: 44rpx;
  text-align: center;
}

.dropdown-count.active {
  background: #ffeaea;
  color: #ff5a5f;
}

/* Tab 下拉箭头 */
.tab-arrow {
  display: inline-block;
  width: 8rpx;
  height: 8rpx;
  border-right: 2rpx solid #999;
  border-bottom: 2rpx solid #999;
  transform: rotate(45deg);
  margin-left: 6rpx;
  margin-bottom: 3rpx;
  transition: transform 0.2s ease, border-color 0.2s ease;
  flex-shrink: 0;
}

.tab.active .tab-arrow {
  border-color: #1b1b1b;
}

.tab-arrow.arrow-up {
  transform: rotate(-135deg);
  margin-bottom: 0;
  margin-top: 3rpx;
}

/* 浏览量图标（B-2 适中圆：加粗 + stroke-linejoin/cap round） */
.views-icon {
  width: 22rpx;
  height: 22rpx;
  display: block;
  flex-shrink: 0;
}

.views-count {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
  line-height: 1;
}
