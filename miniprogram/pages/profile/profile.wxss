/* pages/profile/profile.wxss */
.profile-page {
  min-height: 100vh;
  background: #f8f8f8;
  padding-bottom: 120rpx;
}

/* 用户头部 - 白色卡片 */
.user-header {
  background: #ffffff;
  padding: 32rpx 32rpx 24rpx;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.user-info {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

/* 头像 - 方形圆角 */
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
  color: #333333;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 600;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.user-text {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 4rpx;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #1b1b1b;
}

/* 免费领积分入口 - 在昵称下方 */
.points-entry {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.entry-icon {
  width: 32rpx;
  height: 32rpx;
}

.entry-text {
  font-size: 26rpx;
  color: #6d6c72;
}

/* 右上角积分徽章 - 白色背景阴影 */
.points-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.badge-icon {
  width: 28rpx;
  height: 28rpx;
}

.points-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #e5a030;
}

.points-unit {
  font-size: 20rpx;
  color: #e5a030;
}

/* 标签切换 */
.tabs-container {
  background: #f8f8f8;
  padding: 24rpx 32rpx 0;
}

.tabs {
  display: flex;
  height: 80rpx;
  gap: 48rpx;
}

.tab {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 30rpx;
  color: #999999;
  flex-shrink: 0;
}

.tab.active {
  color: #1b1b1b;
  font-weight: 600;
}

.tab .count {
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  background: #e8e8e8;
  border-radius: 20rpx;
  color: #999999;
  font-weight: normal;
}

.tab.active .count {
  background: #1b1b1b;
  color: #ffffff;
}

/* 内容区域 */
.content-swiper {
  height: calc(100vh - 420rpx);
  background: #f8f8f8;
}

.swiper-item {
  height: 100%;
}

.photo-scroll {
  height: 100%;
  padding: 8rpx;
  box-sizing: border-box;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  row-gap: 10rpx;
  column-gap: 0;
}

.photo-card {
  width: calc(50% - 5rpx);
  height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.photo-image {
  width: 100%;
  height: 100%;
}

.photo-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  color: #ffffff;
}

.photo-title {
  font-size: 26rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.photo-stats {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.9;
}

.stat-liked {
  color: #ff6b6b;
}

/* 右上角操作按钮 */
.photo-more-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  z-index: 10;
  line-height: 1;
}

/* 删除选项红色 */
.modal-option-danger {
  color: #e02020;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-icon-image {
  width: 120rpx;
  height: 180rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-text-dark {
  color: #1b1b1b;
  font-weight: 500;
}

.empty-btn {
  padding: 24rpx 48rpx;
  background: #1b1b1b;
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 已废弃，保持兼容 */
.content-area {
  display: none;
}

/* 未登录提示 */
.login-prompt {
  position: fixed;
  bottom: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.prompt-text {
  font-size: 28rpx;
  color: #999;
}

.login-btn {
  padding: 20rpx 60rpx;
  background: #00ff99;
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  font-size: 30rpx;
}

/* 头像更换底部弹窗 - 与微信原生 ActionSheet 样式一致 */
.avatar-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}

.avatar-modal-content {
  width: 100%;
  height: auto;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 0 0 calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.modal-option {
  text-align: center;
  padding: 32rpx 0;
  font-size: 34rpx;
  color: #1b1b1b;
  font-weight: 500;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
}

.modal-option:first-child {
  border-top: none;
}

/* 微信头像选项：圆形缩略图在上，文字在下 */
.modal-option-wechat {
  padding: 24rpx 0 20rpx;
  border-top: 1rpx solid #e5e5e5;
  border-radius: 0;
  background: #fff;
}

.modal-option-wechat:first-child {
  border-top: none;
}

.wechat-avatar-ring {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #07c160;
  margin: 0 auto 12rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-avatar-img {
  width: 100%;
  height: 100%;
}

.wechat-avatar-text {
  display: block;
  font-size: 34rpx;
  color: #1b1b1b;
  font-weight: 500;
}

.modal-cancel {
  text-align: center;
  font-size: 34rpx;
  color: #1b1b1b;
  padding: 32rpx 0;
  background: #ffffff;
  margin-top: 16rpx;
  border-radius: 0 0 0 0;
  font-weight: 500;
}