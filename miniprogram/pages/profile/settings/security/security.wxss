/* pages/profile/settings/security/security.wxss */

.security-page {
  min-height: 100vh;
  background: #f8f8f8;
}

.page-body {
  padding: 32rpx 0 200rpx;
}

.section-title {
  font-size: 26rpx;
  color: #bbb;
  padding: 24rpx 16rpx 16rpx;
  font-weight: 400;
}

.settings-card {
  background: #ffffff;
  overflow: hidden;
}

.item {
  display: flex;
  align-items: center;
  padding: 14rpx 32rpx;
  min-height: 104rpx;
  position: relative;
}

.item:active {
  background: #f5f5f5;
}

.item.no-arrow {
  cursor: default;
}

.item.no-arrow:active {
  background: transparent;
}

.item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 112rpx;
  right: 32rpx;
  height: 1rpx;
  background: #f0f0f0;
}

.item:last-child::after {
  display: none;
}

.item-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-icon image {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.item-text {
  flex: 1;
  font-size: 30rpx;
  color: #1b1b1b;
  white-space: nowrap;
}

.item-value {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}

.item-arrow {
  font-size: 32rpx;
  color: #bbb;
  font-weight: 300;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-name {
  font-size: 30rpx;
  color: #1b1b1b;
  font-weight: 500;
}

.user-id {
  font-size: 24rpx;
  color: #999;
}

.bind-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.bind-tag.binded {
  background: #fff4f4;
  color: #ff4444;
}

.bind-tag.unbinded {
  background: #f5f5f5;
  color: #999;
}

.item.danger .item-text {
  color: #ff4444;
}

.tip-box {
  margin: 32rpx 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.phone-bind-btn {
  width: 100%;
  margin: 0;
  padding: 14rpx 32rpx;
  min-height: 104rpx;
  background: #ffffff;
  border: none;
  border-radius: 0;
  line-height: normal;
  text-align: left;
  font-size: inherit;
  font-weight: normal;
  color: inherit;
  box-sizing: border-box;
}

.phone-bind-btn::after {
  border: none;
}

.item-hover {
  background: #f5f5f5;
}