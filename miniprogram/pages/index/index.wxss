/* 首页样式 - 新设计 */

.page-root {
  position: relative;
  height: 100vh;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f8f8f8;
  transition: transform 420ms cubic-bezier(0.25, 0.1, 0.25, 1),
              filter 420ms cubic-bezier(0.25, 0.1, 0.25, 1);
}

.feed-underlay {
  will-change: opacity;
}

.container.feed-dimmed {
  overflow: hidden;
}

/* 详情打开/拖拽时：该卡片仅占位，露出首页背景色，无图无骨架 */
.photo-card.card-slot-placeholder {
  background: transparent;
  box-shadow: none;
  pointer-events: none;
}

.card-slot-hole {
  width: 100%;
  background: transparent;
}

/* 顶栏白底 */
.home-header {
  width: 100%;
  background-color: #ffffff;
  flex-shrink: 0;
}

.capsule-spacer {
  width: 100%;
}

/* 搜索栏：胶囊下方独占一行，全宽不与胶囊抢位置 */
.top-bar {
  display: flex;
  align-items: center;
  padding: 0 24rpx 12rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  height: 64rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 20rpx;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
  opacity: 0.4;
  line-height: 1;
  vertical-align: middle;
}

.search-input {
  flex: 1;
  height: 64rpx;
  font-size: 28rpx;
  color: #333;
}

.search-input::placeholder {
  color: #999;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
}

.clear-icon {
  font-size: 32rpx;
  color: #999;
  line-height: 1;
}

/* 内容标题行 */
.content-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx 12rpx;
}

.content-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1b1b1b;
}

.sort-dropdown-wrap {
  position: relative;
}

.sort-dropdown {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 24rpx;
}

.sort-text {
  font-size: 26rpx;
  color: #666;
}

.sort-arrow {
  font-size: 22rpx;
  color: #999;
  margin-left: 6rpx;
  transition: transform 0.2s;
}

.sort-arrow.arrow-up {
  transform: rotate(180deg);
}

.sort-menu {
  position: absolute;
  top: 100%;
  right: 0;
  margin-top: 8rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
  z-index: 100;
  min-width: 200rpx;
}

.sort-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  font-size: 26rpx;
  color: #666;
}

.sort-option.active {
  color: #1b1b1b;
  font-weight: 500;
}

.sort-check {
  font-size: 26rpx;
  color: #1b1b1b;
  margin-left: 16rpx;
}

/* 地点标签栏 */
.location-bar {
  background-color: #fff;
  padding: 12rpx 0 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.location-scroll {
  white-space: nowrap;
}

.location-content {
  display: inline-flex;
  align-items: center;
  padding: 0 24rpx;
}

.location-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  padding: 0 20rpx;
  margin-right: 12rpx;
  background-color: #f5f5f5;
  border-radius: 26rpx;
  font-size: 24rpx;
  color: #666;
}

.location-tag.active {
  background-color: #1b1b1b;
  color: #fff;
}

.location-tag:last-child {
  margin-right: 0;
}

.location-pin {
  width: 24rpx;
  height: 24rpx;
  margin-right: 4rpx;
  opacity: 0.7;
}

.location-tag.active .location-pin {
  opacity: 1;
  /* 白色图标：用亮度滤镜反色 */
  filter: brightness(10);
}

/* 瀑布流 */
.waterfall-scroll {
  flex: 1;
  height: 0;
}

.waterfall-container {
  display: flex;
  padding: 0 12rpx;
  gap: 12rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 卡片 */
.photo-card {
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-image-wrapper {
  position: relative;
  width: 100%;
  overflow: hidden;
  background-color: #f0f0f0;
}

.card-image {
  width: 100%;
  height: 100%;
}

/* 地点badge（毛玻璃风格） */
.location-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  display: flex;
  align-items: center;
  background-color: rgba(0, 0, 0, 0.45);
  border-radius: 16rpx;
  padding: 4rpx 12rpx;
}

.location-badge-icon {
  width: 20rpx;
  height: 20rpx;
  margin-right: 2rpx;
  filter: brightness(10);
}

.location-badge-text {
  font-size: 20rpx;
  color: #fff;
}

.card-content {
  padding: 20rpx;
}

.card-text-row {
  display: block;
  font-size: 26rpx;
  line-height: 1.4;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-title {
  color: #444;
  font-weight: 500;
}

.card-desc {
  color: #666;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.author-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.author-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background-color: #f0f0f0;
  flex-shrink: 0;
}

.author-meta {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.author-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-date {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.like-info {
  display: flex;
  align-items: center;
  margin-left: 0;
  flex-shrink: 0;
}

.like-info.liked .like-count {
  color: #ff4444;
}

.like-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 2rpx;
}

.like-count {
  font-size: 24rpx;
  color: #333;
  min-width:20rpx;
  max-width: 120rpx;
  text-align: left;
  margin-left: 4rpx;
}
.like-count.large { font-size: 22rpx; }
.like-count.huge  { font-size: 20rpx; }

/* 加载状态 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #f0f0f0;
  border-top-color: #1b1b1b;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
