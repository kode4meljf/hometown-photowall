/* pages/upload/upload.wxss */
.upload-page {
  min-height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
}

/* 顶部大图预览区 */
.preview-area {
  width: 100%;
  height: 500rpx;
  background: #fff;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #666;
}

/* 删除按钮：预览区右上角 */
.preview-delete-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  font-size: 36rpx;
  text-align: center;
  line-height: 56rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.image-counter {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  color: #000;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* ─── 缩略图栏 ─── */
.thumbnail-bar {
  padding: 16rpx 0;
  display: flex;
  align-items: center;
}

/* 滚动容器：占满 bar 剩余宽度，溢出时触发水平滚动 */
.thumbnail-scroll {
  flex: 1;
  width: 100%;
  min-width: 0;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
}
.thumbnail-scroll::-webkit-scrollbar {
  display: none;
}

/* 缩略图组：inline-flex 由内容决定宽度，居中靠 margin */
.thumbnail-row {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  margin: 0 auto;
}
.thumbnail-row.overflow {
  margin: 0;
}

/* 缩略图项 */
.thumbnail-item {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  border: 4rpx solid transparent;
  transition: border-color 0.2s;
}
.thumbnail-item.selected {
  border-color: #ff4d4f;
}
.thumbnail-image {
  width: 100%;
  height: 100%;
}

/* 添加按钮：固定在 bar 最右侧 */
.thumbnail-add {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 16rpx;
  margin-left: 16rpx;
}

.add-icon {
  font-size: 44rpx;
  color: #999;
}

/* ─── 表单区域 ─── */
.form-scroll {
  flex: 1;
  background: #fff;
}

.form-section {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.title-input {
  width: 100%;
  height: 65rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  background: transparent;
  letter-spacing: 2rpx;
}

.title-input.highlight {
  color: #ff4d4f;
}

.desc-input {
  width: 100%;
  height: 120rpx;
  font-size: 28rpx;
  color: #666;
  background: transparent;
}

.placeholder {
  color: #bbb;
}

/* 地点选择 */
.location-section {
  margin-top: 32rpx;
  border-top: 1rpx solid #eee;
  padding-top: 24rpx;
}

.location-header {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
}

/* 选中后：整体白色背景（无圆角），文字替换为老根茶 */
.location-header.has-location {
  background: #ffffff;
  border-radius: 0;
}

.location-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  object-fit: contain;
  object-position: center;
  vertical-align: middle;
  flex-shrink: 0;
}

.location-label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* X 清除按钮：flex 自动撑到最右，纯白背景 */
.location-clear-btn {
  flex-shrink: 0;
  margin-left: auto;
  width: 36rpx;
  height: 36rpx;
  background: #ffffff;
  color: #999;
  font-size: 32rpx;
  text-align: center;
  line-height: 36rpx;
}

.location-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 16rpx;
}

.location-tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid transparent;
}

.location-tag.active {
  background: #fff2f0;
  color: #ff4d4f;
  border-color: #ff4d4f;
}

.custom-location-input {
  width: 160rpx;
  height: 56rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
}

/* 底部发布按钮 */
.submit-bar {
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
}

.submit-btn {
  height: 88rpx;
  background: #fff;
  color: #000;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  line-height: 88rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);
}

.submit-btn.submitting {
  background: #ccc;
}
