/* 评论区（与 detail 页一致） */
.comment-count-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #fff;
  box-sizing: border-box;
}

.comment-count-row--with-action {
  min-height: 88rpx;
}

.comment-count-row--with-delete {
  min-height: 88rpx;
}

.comment-action-slot,
.comment-delete-slot {
  flex-shrink: 0;
  width: 120rpx;
  height: 56rpx;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.comment-count-text {
  font-size: 28rpx;
  color: #666;
  flex: 1;
}

.comment-delete-btn {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #e02020;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(224, 32, 32, 0.16);
}

.comment-delete-btn-pressed {
  transform: scale(0.9);
  opacity: 0.78;
}

.comment-report-btn {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
  background: #f5f5f5;
  border-radius: 28rpx;
}

.comment-report-btn-hover {
  opacity: 0.88;
}

.comment-report-btn-pressed {
  transform: scale(0.94);
  opacity: 0.78;
}

.comment-list {
  padding: 0 24rpx 24rpx;
  background: #fff;
}

.comment-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.comment-item-row {
  display: flex;
  gap: 16rpx;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.comment-author {
  font-size: 28rpx;
  font-weight: 500;
  color: #1b1b1b;
}

.comment-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.comment-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.comment-footer-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.reply-text-btn {
  font-size: 24rpx;
  color: #333;
}

.comment-action-link {
  font-size: 24rpx;
  color: #888;
  margin-left: 12rpx;
}

.like-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.like-btn image {
  width: 36rpx;
  height: 36rpx;
}

.like-btn text {
  font-size: 24rpx;
  color: #999;
}

.reply-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 8rpx;
}

.reply-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.reply-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.reply-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
}

.reply-author {
  font-size: 24rpx;
  font-weight: 500;
  color: #1b1b1b;
}

.reply-arrow {
  color: #999;
}

.reply-target {
  font-size: 24rpx;
  color: #1b1b1b;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reply-content-wrap {
  padding-left: 44rpx;
}

.reply-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.reply-footer {
  padding-left: 44rpx;
}

.replies-actions {
  display: flex;
  gap: 80rpx;
  margin-top: 8rpx;
}

.expand-replies,
.expand-more-btn,
.collapse-btn {
  font-size: 26rpx;
  color: #888;
}

.expand-replies::before {
  content: '——— ';
  opacity: 0.2;
}

.dash {
  opacity: 0.2;
}

.btn-text {
  font-weight: 500;
}

.comment-item.highlight {
  background: rgba(255, 235, 59, 0.25);
  border-radius: 12rpx;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #00ff99;
  border-radius: 50%;
  animation: overlay-comment-bounce 1.4s infinite ease-in-out both;
}

.dot1 { animation-delay: -0.32s; }
.dot2 { animation-delay: -0.16s; }

@keyframes overlay-comment-bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.load-more-done {
  padding: 40rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #999;
}
