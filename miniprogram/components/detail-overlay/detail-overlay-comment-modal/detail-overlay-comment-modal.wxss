.comment-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: var(--z-detail-comment);
}

.comment-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.comment-modal-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transition: padding-bottom 0.2s ease;
  z-index: 2;
  box-sizing: border-box;
}

.comment-modal-content.keyboard-up {
  /* 键盘占位由内联 padding-bottom 控制 */
}

.comment-emoji-area {
  flex-shrink: 0;
  overflow: hidden;
  border-top: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.comment-input-row {
  padding: 20rpx 24rpx 0;
}

.comment-textarea {
  width: 100%;
  min-height: 76rpx;
  max-height: 200rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #1b1b1b;
  padding: 14rpx 20rpx;
  box-sizing: border-box;
}

.comment-toolbar-row {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  gap: 12rpx;
}

.emoji-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.emoji-btn-active {
  background: #f0f0f0;
}

.emoji-btn image {
  width: 44rpx;
  height: 44rpx;
}

.emoji-quick-row {
  width: 100%;
  white-space: nowrap;
  border-top: 1rpx solid #f0f0f0;
}

.emoji-quick-inner {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx 16rpx;
  gap: 4rpx;
}

.emoji-quick-item {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.emoji-panel-scroll {
  height: 100%;
  box-sizing: border-box;
}

.emoji-panel-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 12rpx 16rpx 16rpx;
}

.emoji-panel-item {
  width: 12.5%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.toolbar-spacer {
  flex: 1;
}

.comment-send-btn {
  padding: 0 32rpx;
  height: 64rpx;
  background: #00ff99;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.comment-send-btn.disabled {
  background: #e8e8e8;
  color: #aaa;
  pointer-events: none;
}
