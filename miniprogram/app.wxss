/* app.wxss - 全局样式 */

/* 统一主题色 */
page {
  --primary-color: #00ff99;
  --bg-color: #f5f5f7;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border-color: #e0e0e0;

  /* z-index 刻度 — 详见 utils/zIndex.js */
  --z-dropdown-mask: 990;
  --z-dropdown: 991;
  --z-tab-bar: 1000;
  --z-page-sheet: 9999;
  --z-modal: 10000;
  --z-detail-overlay: 10001;
  --z-detail-comment: 10010;
  --z-detail-like: 10011;
  --z-detail-preview: 10020;
  --z-detail-login: 10030;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background: #ffffff;
  min-height: 100vh;
}

/* 通用样式 */
.container {
  padding: 20rpx;
}

.card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background: var(--primary-color);
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: #f5f5f7;
  color: var(--text-secondary);
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.btn-danger {
  background: #ff4444;
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

/* 输入框 */
.input {
  background: #f5f5f7;
  border: 1rpx solid var(--border-color);
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-green {
  background: #e0fff0;
  color: #00cc77;
}

.tag-blue {
  background: #e3f2fd;
  color: #2196F3;
}

.tag-orange {
  background: #fff3e0;
  color: #FF9800;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 40rpx;
  color: var(--text-hint);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: var(--text-hint);
}

/* 头像 */
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--primary-color);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}