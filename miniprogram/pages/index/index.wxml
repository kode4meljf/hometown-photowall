<!-- 首页 - 新设计 -->
<view class="container">
  <!-- 搜索栏 -->
  <view class="top-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder=" 搜索" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearchConfirm"
      />
      <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">
        <text class="clear-icon">×</text>
      </view>
    </view>
  </view>

  <!-- 地点标签栏（独立行） -->
  <view class="location-bar" wx:if="{{locations.length > 0}}">
    <scroll-view class="location-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="location-content">
        <view 
          class="location-tag {{selectedLocation === '' ? 'active' : ''}}"
          bindtap="onLocationTap"
          data-location=""
        >
          <text>全部</text>
        </view>
        <view 
          wx:for="{{locations}}" 
          wx:key="*this"
          class="location-tag {{selectedLocation === item ? 'active' : ''}}"
          bindtap="onLocationTap"
          data-location="{{item}}"
        >
          <image class="location-pin" src="/assets/icons/location.png" mode="aspectFit" />
          <text>{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 内容标题行 -->
  <view class="content-header">
    <text class="content-title">发现</text>
    <view class="sort-dropdown-wrap">
      <view class="sort-dropdown" bindtap="onSortToggle">
        <text class="sort-text">{{sortType === 'likes' ? '最多赞' : '最新'}}</text>
        <text class="sort-arrow {{sortMenuShow ? 'arrow-up' : ''}}">▾</text>
      </view>
      <view class="sort-menu" wx:if="{{sortMenuShow}}">
        <view class="sort-option {{sortType === 'latest' ? 'active' : ''}}" bindtap="onSortSelect" data-sort="latest">
          <text>最新</text>
          <text class="sort-check" wx:if="{{sortType === 'latest'}}">✓</text>
        </view>
        <view class="sort-option {{sortType === 'likes' ? 'active' : ''}}" bindtap="onSortSelect" data-sort="likes">
          <text>最多赞</text>
          <text class="sort-check" wx:if="{{sortType === 'likes'}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 瀑布流内容 -->
  <scroll-view 
    class="waterfall-scroll" 
    scroll-y 
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="loadMore"
    bindrefresherrefresh="onRefresh"
    refresher-enabled="{{true}}"
    refresher-triggered="{{isRefreshing}}"
  >
    <view class="waterfall-container" bindtap="onContentTap">
      <!-- 左列 -->
      <view class="waterfall-column" id="left-column">
        <view 
          wx:for="{{leftPosts}}" 
          wx:key="id"
          class="photo-card"
          bindtap="goToDetail"
          data-id="{{item.id}}"
        >
          <view class="card-image-wrapper" style="height: {{item.cardHeight}}px;">
            <image 
              class="card-image" 
              src="{{item.imageUrl}}" 
              mode="aspectFill"
              lazy-load
            />
            <view class="location-badge" wx:if="{{item.location}}">
              <image class="location-badge-icon" src="/assets/icons/location.png" mode="aspectFit" />
              <text class="location-badge-text"> {{item.location}}</text>
            </view>
          </view>
          <view class="card-content">
            <view class="card-text-row" wx:if="{{item.title || item.description}}"><text class="card-title" wx:if="{{item.title}}">{{item.title}}</text><text wx:if="{{item.title && item.description}}"> </text><text class="card-desc" wx:if="{{item.description}}">{{item.description}}</text></view>
            <view class="card-footer">
              <view class="author-info">
                <image class="author-avatar" src="{{item.authorAvatar || '/assets/icons/default-avatar.png'}}" mode="aspectFill"/>
                <view class="author-meta">
                  <text class="author-name">{{item.author || '匿名用户'}}</text>
                  <text class="post-date">{{item._formattedDate}}</text>
                </view>
              </view>
              <view class="like-info {{item.liked ? 'liked' : ''}}" catchtap="onLikeTap" data-id="{{item.id}}" data-index="{{index}}" data-column="left">
                <image class="like-icon" src="{{item.liked ? '/assets/icons/like-active.png' : '/assets/icons/like.png'}}" mode="aspectFit"/>
                <text class="like-count {{item._likesCls}}">{{item._likesText}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 右列 -->
      <view class="waterfall-column" id="right-column">
        <view 
          wx:for="{{rightPosts}}" 
          wx:key="id"
          class="photo-card"
          bindtap="goToDetail"
          data-id="{{item.id}}"
        >
          <view class="card-image-wrapper" style="height: {{item.cardHeight}}px;">
            <image 
              class="card-image" 
              src="{{item.imageUrl}}" 
              mode="aspectFill"
              lazy-load
            />
            <view class="location-badge" wx:if="{{item.location}}">
              <image class="location-badge-icon" src="/assets/icons/location.png" mode="aspectFit" />
              <text class="location-badge-text"> {{item.location}}</text>
            </view>
          </view>
          <view class="card-content">
            <view class="card-text-row" wx:if="{{item.title || item.description}}"><text class="card-title" wx:if="{{item.title}}">{{item.title}}</text><text wx:if="{{item.title && item.description}}"> </text><text class="card-desc" wx:if="{{item.description}}">{{item.description}}</text></view>
            <view class="card-footer">
              <view class="author-info">
                <image class="author-avatar" src="{{item.authorAvatar || '/assets/icons/default-avatar.png'}}" mode="aspectFill"/>
                <view class="author-meta">
                  <text class="author-name">{{item.author || '匿名用户'}}</text>
                  <text class="post-date">{{item._formattedDate}}</text>
                </view>
              </view>
              <view class="like-info {{item.liked ? 'liked' : ''}}" catchtap="onLikeTap" data-id="{{item.id}}" data-index="{{index}}" data-column="right">
                <image class="like-icon" src="{{item.liked ? '/assets/icons/like-active.png' : '/assets/icons/like.png'}}" mode="aspectFit"/>
                <text class="like-count {{item._likesCls}}">{{item._likesText}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{isLoading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && posts.length > 0}}">
      <text>没有更多了</text>
    </view>
    <view class="empty-state" wx:if="{{!isLoading && posts.length === 0}}">
      <image class="empty-icon" src="/assets/icons/empty-photos.png" mode="aspectFit"/>
      <text class="empty-text">暂无内容</text>
    </view>
    
  </scroll-view>
</view>
