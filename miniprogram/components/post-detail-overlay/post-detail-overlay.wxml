<view class="overlay-root" wx:if="{{visible}}" catchtouchmove="noop">
  <view class="overlay-mask {{maskShow ? 'mask-visible' : ''}} {{panelDragging ? 'mask-no-transition' : ''}}" style="{{maskStyle}}" catchtap="onMaskTap"></view>

  <view
    wx:if="{{heroVisible && (heroPhase === 'exiting')}}"
    class="hero-media-wrap {{heroAnimating ? 'hero-transition' : ''}}"
    style="{{heroMediaStyle}};opacity:{{heroCoverOpacity}};"
    bindtransitionend="onHeroTransitionEnd"
  >
    <image class="hero-media-img" src="{{coverUrl}}" mode="{{heroMediaMode}}" />
  </view>

  <view
    wx:if="{{(heroPhase === 'entering' || heroPhase === 'exiting') && (titleText || descText)}}"
    class="fly-title"
    style="{{heroTitleStyle}}"
  >
    <text class="card-title" wx:if="{{titleText}}">{{titleText}}</text>
    <text wx:if="{{titleText && descText}}"> </text>
    <text class="card-desc" wx:if="{{descText}}">{{descText}}</text>
  </view>

  <view
    class="detail-panel {{panelShow ? 'panel-show' : ''}} {{shellReady ? 'detail-panel-ready' : ''}} {{shellScaling ? 'shell-scaling' : ''}} {{panelExiting ? 'panel-exiting' : ''}} {{panelDragging ? 'panel-dragging' : ''}}"
    style="{{panelTransformStyle}} {{panelChromeStyle}}"
    bindtransitionend="onPanelTransitionEnd"
  >
    <view
      class="panel-header dismiss-zone {{panelExitChrome ? 'panel-exit-chrome' : ''}}"
      wx:if="{{shellReady}}"
      style="padding-top:{{headerPaddingTop}}px;padding-right:{{headerPaddingRight}}px;height:{{navBarHeight}}px;"
      bindtouchstart="onDismissTouchStart"
      bindtouchmove="onDismissTouchMove"
      bindtouchend="onDismissTouchEnd"
      bindtouchcancel="onDismissTouchEnd"
    >
      <view class="panel-header-left">
        <view class="back-btn" catchtap="onBack"><text>‹</text></view>
        <block wx:if="{{post}}">
          <image class="author-avatar" src="{{post.authorAvatar}}" mode="aspectFill" />
          <text class="author-name">{{post.author}}</text>
        </block>
        <block wx:elif="{{authorAvatar || authorName}}">
          <image class="author-avatar" src="{{authorAvatar}}" mode="aspectFill" />
          <text class="author-name">{{authorName}}</text>
        </block>
      </view>
    </view>

    <scroll-view
      wx:if="{{shellReady}}"
      class="panel-scroll"
      scroll-y="{{!scrollLocked}}"
      scroll-top="{{commentScrollTop}}"
      bindscroll="onCommentScroll"
      bindscrolltolower="onScrollToLower"
    >
      <view class="image-section image-slot image-slot--stage" id="image-slot" style="height:{{imageSlotHeight}}px;" bindtap="onImageTap">
        <view class="media-skeleton" wx:if="{{mediaSkeleton && !swiperShown}}">
          <view class="progress-bar progress-bar--skeleton" wx:if="{{photoCount > 1}}">
            <view
              wx:for="{{skeletonSegments}}"
              wx:key="*this"
              class="progress-segment {{index === 0 ? 'done' : 'todo'}}"
            ></view>
          </view>
          <view class="photo-index-badge badge-show" wx:if="{{photoCount > 1}}">
            <text class="badge-text">1/{{photoCount}}</text>
          </view>
        </view>
        <view
          class="panel-photo-wrap photo-letterbox {{swiperShown ? 'swiper-show' : ''}} {{heroFadingOut ? 'swiper-crossfade' : ''}}"
          style="opacity:{{swiperShown ? swiperRevealOpacity : 0}};"
        >
          <swiper
            wx:if="{{post}}"
            class="photo-swiper"
            current="{{currentPhotoIndex}}"
            bindchange="onSwiperChange"
            duration="300"
          >
            <swiper-item wx:for="{{post.photos}}" wx:key="order">
              <image
                class="photo-image"
                src="{{item.imageUrl}}"
                mode="{{photoMode}}"
                data-index="{{index}}"
                bindload="onPhotoLoad"
              />
            </swiper-item>
          </swiper>
          <view class="progress-bar" wx:if="{{post && post.photos.length > 1 && swiperShown}}">
            <view
              wx:for="{{post.photos}}"
              wx:key="order"
              class="progress-segment {{index <= currentPhotoIndex ? 'done' : 'todo'}}"
            ></view>
          </view>
          <view class="photo-index-badge {{indexBadgeVisible ? 'badge-show' : ''}}" wx:if="{{post && post.photos.length > 1 && swiperShown}}">
            <text class="badge-text">{{currentPhotoIndex + 1}}/{{post.photos.length}}</text>
          </view>
        </view>
      </view>

      <view
        class="dismiss-zone"
        bindtouchstart="onDismissTouchStart"
        bindtouchmove="onDismissTouchMove"
        bindtouchend="onDismissTouchEnd"
        bindtouchcancel="onDismissTouchEnd"
      >
        <view class="panel-body-below">
          <block wx:if="{{shellReady && post}}">
            <view class="content-section content-reveal {{contentReveal ? 'show' : ''}}">
              <text class="description" wx:if="{{post.titleDesc}}">{{post.titleDesc}}</text>
              <text class="date">{{post.date}}</text>
            </view>

            <view class="divider content-reveal {{contentReveal ? 'show' : ''}} {{panelExitChrome ? 'panel-exit-chrome' : ''}}"></view>

            <detail-overlay-comments
              post="{{post}}"
              loading="{{loading}}"
              contentReveal="{{contentReveal}}"
              panelExitChrome="{{panelExitChrome}}"
              canAdminDelete="{{canAdminDelete}}"
              highlightCommentId="{{highlightCommentId}}"
              commentsCountText="{{commentsCountText}}"
              deleteBtnPressed="{{deleteBtnPressed}}"
              reportBtnPressed="{{reportBtnPressed}}"
              commentsLoading="{{commentsLoading}}"
              hasMoreComments="{{hasMoreComments}}"
              bind:deletebtntouchstart="onDeleteBtnTouchStart"
              bind:deletebtntouchend="onDeleteBtnTouchEnd"
              bind:reportbtntouchstart="onReportBtnTouchStart"
              bind:reportbtntouchend="onReportBtnTouchEnd"
              bind:deletepost="onDeletePost"
              bind:reportposttap="onReportPostTap"
              bind:replytap="handleReplyTap"
              bind:deletecommenttap="onDeleteCommentTap"
              bind:reportcommenttap="onReportCommentTap"
              bind:togglecommentlike="toggleCommentLike"
              bind:expandreplies="expandReplies"
              bind:collapsereplies="collapseReplies"
            />
          </block>
        </view>
      </view>
    </scroll-view>

    <view
      class="dismiss-zone"
      bindtouchstart="onDismissTouchStart"
      bindtouchmove="onDismissTouchMove"
      bindtouchend="onDismissTouchEnd"
      bindtouchcancel="onDismissTouchEnd"
    >
      <detail-overlay-bottom-bar
        shellReady="{{shellReady}}"
        post="{{post}}"
        panelExitChrome="{{panelExitChrome}}"
        likesCountText="{{likesCountText}}"
        commentsCountText="{{commentsCountText}}"
        bind:focuscomment="focusCommentInput"
        bind:like="handleLike"
      />
    </view>
  </view>

  <detail-overlay-comment-modal
    visible="{{showCommentInput}}"
    replyToAuthor="{{replyToAuthor}}"
    commentContent="{{commentContent}}"
    commentFocus="{{commentFocus}}"
    showEmojiPanel="{{showEmojiPanel}}"
    commentBottomInset="{{commentBottomInset}}"
    emojiPanelEmojis="{{emojiPanelEmojis}}"
    quickEmojis="{{quickEmojis}}"
    sendDisabled="{{sendDisabled}}"
    bind:close="hideCommentInput"
    bind:input="onCommentInput"
    bind:submit="submitComment"
    bind:toggleemoji="toggleEmojiPanel"
    bind:quickemoji="onQuickEmojiTap"
    bind:keyboardheight="_onKeyboardHeightChange"
    bind:focus="_onCommentInputFocus"
    bind:blur="_onCommentInputBlur"
  />

  <detail-overlay-report-modal
    visible="{{showReportModal}}"
    reportReason="{{reportReason}}"
    reportDetail="{{reportDetail}}"
    reportSubmitting="{{reportSubmitting}}"
    bind:close="closeReportModal"
    bind:detailinput="onReportDetailInput"
    bind:submit="submitReport"
  />

  <detail-overlay-preview
    visible="{{isPreviewMode}}"
    previewBgBlack="{{previewBgBlack}}"
    previewTransform="{{previewTransform}}"
    previewBgStyle="{{previewBgStyle}}"
    previewAnimClass="{{previewAnimClass}}"
    previewOpacity="{{previewOpacity}}"
    overlayOpacity="{{overlayOpacity}}"
    previewDismissDragging="{{previewDismissDragging}}"
    previewTouchCapture="{{previewTouchCapture}}"
    bottomBarVisible="{{bottomBarVisible}}"
    showLikeAnim="{{showLikeAnim}}"
    previewProgressStyle="{{previewProgressStyle}}"
    previewProgressVisible="{{previewProgressVisible}}"
    currentPhotoIndex="{{currentPhotoIndex}}"
    indexBadgeVisible="{{indexBadgeVisible}}"
    post="{{post}}"
    bind:touchstart="onPreviewTouchStart"
    bind:touchmove="onPreviewTouchMove"
    bind:touchend="onPreviewTouchEnd"
    bind:swiperchange="onPreviewSwiperChange"
    bind:photoload="onPreviewPhotoLoad"
    bind:exit="exitPreview"
    bind:download="downloadPreviewImage"
  />

  <view class="overlay-login-modal">
    <login-modal
      visible="{{loginModalShow}}"
      z-index="{{loginModalZIndex}}"
      bind:close="onLoginModalClose"
      bind:success="onLoginSuccess"
    />
  </view>
</view>
