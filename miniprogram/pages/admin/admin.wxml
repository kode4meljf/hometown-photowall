<!-- pages/admin/admin.wxml -->
<view class="admin-page">
  <!-- 未登录/非管理员状态 -->
  <view class="not-admin" wx:if="{{!isAdmin}}">
    <text class="icon">🔒</text>
    <text class="text">您不是管理员，无法访问</text>
    <button class="login-btn" bindtap="goToLogin" wx:if="{{!isLoggedIn}}">去登录</button>
  </view>

  <!-- 管理员内容 -->
  <view class="admin-content" wx:else>
    <!-- 统计卡片 -->
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-value">{{stats.totalPhotos || 0}}</text>
        <text class="stat-label">📷 照片总数</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.totalUsers || 0}}</text>
        <text class="stat-label">👥 用户数量</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.totalLikes || 0}}</text>
        <text class="stat-label">❤️ 点赞总数</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.totalComments || 0}}</text>
        <text class="stat-label">💬 评论总数</text>
      </view>
    </view>

    <!-- Tab 切换 -->
    <view class="tab-bar">
      <view class="tab {{currentTab === 'photos' ? 'active' : ''}}" bindtap="switchTab" data-tab="photos">
        <text>📷 照片管理</text>
        <text class="badge">{{photos.length}}</text>
      </view>
      <view class="tab {{currentTab === 'users' ? 'active' : ''}}" bindtap="switchTab" data-tab="users">
        <text>👥 用户管理</text>
        <text class="badge">{{users.length}}</text>
      </view>
    </view>

    <!-- 照片管理 -->
    <view class="section" wx:if="{{currentTab === 'photos'}}">
      <view class="section-header">
        <text class="section-title">照片列表</text>
        <text class="refresh-btn" bindtap="loadPhotos">🔄 刷新</text>
      </view>
      
      <view class="empty-tip" wx:if="{{photos.length === 0 && !loading}}">
        <text>暂无照片</text>
      </view>

      <view class="photo-list" wx:else>
        <view class="photo-item" wx:for="{{photos}}" wx:key="id">
          <image class="photo-thumb" src="{{item.imageUrl}}" mode="aspectFill" />
          <view class="photo-info">
            <text class="photo-title">{{item.title}}</text>
            <view class="photo-meta">
              <text>📷 {{item.author}}</text>
              <text>📅 {{item.date}}</text>
            </view>
            <view class="photo-stats-row">
              <text>❤️ {{item.likes || 0}}</text>
              <text>👁️ {{item.views || 0}}</text>
              <text>💬 {{item.commentCount || 0}}</text>
            </view>
          </view>
          <view class="photo-actions">
            <text class="delete-btn" bindtap="handleDeletePhoto" data-id="{{item.id}}">删除</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 用户管理 -->
    <view class="section" wx:if="{{currentTab === 'users'}}">
      <view class="section-header">
        <text class="section-title">用户列表</text>
        <text class="refresh-btn" bindtap="loadUsers">🔄 刷新</text>
      </view>
      
      <view class="empty-tip" wx:if="{{users.length === 0 && !loading}}">
        <text>暂无用户</text>
      </view>

      <view class="user-list" wx:else>
        <view class="user-item" wx:for="{{users}}" wx:key="id">
          <view class="user-avatar">{{item.nickname ? item.nickname[0] : '匿'}}</view>
          <view class="user-info">
            <view class="user-name">
              <text class="nickname">{{item.nickname || '匿名用户'}}</text>
              <text class="role-tag {{item.role}}">{{item.role === 'admin' ? '管理员' : '用户'}}</text>
            </view>
            <text class="username">@{{item.username}}</text>
            <view class="user-stats">
              <text>📷 {{item.photoCount || 0}}张照片</text>
              <text>💬 {{item.commentCount || 0}}条评论</text>
            </view>
          </view>
          <text class="user-date">{{item.date}}</text>
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <button class="logout-btn" bindtap="handleLogout">退出登录</button>
    </view>
  </view>
</view>