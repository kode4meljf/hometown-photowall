/* pages/comments/comments.wxss */
.page {
  height: 100vh;
  background: var(--bg, #f8f8f8);
  display: flex;
  flex-direction: column;
}

/* 固定头部：标题 + Tab bar */
.header-fixed {
  background: #fff;
  border-bottom: 1px solid #eee;
  flex-shrink: 0;
}

/* Tab bar */
.tab-bar {
  display: flex;
}

/* Swiper 区域 */
.tab-swiper {
  flex: 1;
  height: calc(100vh - 96rpx);  /* 减去 tab-bar 高度 */
}

.tab-swiper swiper-item {
  height: 100%;
  overflow: hidden;
}

/* Tab content scroll area */
.tab-scroll {
  height: 100%;
}

.tab-item {
  flex: 1;
  text-align: center;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  position: relative;
}

.tab-item.active {
  color: #1b1b1b;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: #1b1b1b;
  border-radius: 2rpx;
}

/* Content area */
.tab-content {
  padding: 24rpx;
}

/* Summary card (received tab) */
.summary-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.summary-icon {
  width: 80rpx;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary-icon image {
  width: 44rpx;
  height: 44rpx;
}

.summary-nums {
  display: flex;
  gap: 40rpx;
}

.summary-num-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1b1b1b;
  line-height: 1;
}

.summary-num-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* Comment item */
.comment-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 20rpx;
}

.comment-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.comment-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #ff4444;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-author-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.comment-author {
  font-size: 26rpx;
  font-weight: 600;
  color: #1b1b1b;
}

.comment-time {
  font-size: 22rpx;
  color: #bbb;
}

.comment-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 12rpx;
  word-break: break-all;
}

/* Post reference (thumbnail + title) */
.post-ref {
  display: flex;
   align-items: center;
  gap: 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.post-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  background: #e0e0e0;
  flex-shrink: 0;
}

.post-title {
  font-size: 24rpx;
  color: #666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-arrow {
  font-size: 24rpx;
  color: #bbb;
  flex-shrink: 0;
}

/* Action row */
.comment-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #999;
}

.action-btn image {
  width: 28rpx;
  height: 28rpx;
}

/* Sent tab - horizontal card style */
.sent-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.sent-thumb-wrap {
  position: relative;
  flex-shrink: 0;
}

.sent-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.sent-thumb-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
}

.sent-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.sent-title {
  font-size: 26rpx;
  color: #1b1b1b;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 12rpx;
}

.sent-comment-bubble {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 12rpx;
}

.sent-comment-text {
  font-size: 24rpx;
  color: #333;
  line-height: 1.5;
}

.sent-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sent-time {
  font-size: 22rpx;
  color: #bbb;
}

.sent-stats {
  display: flex;
  gap: 20rpx;
}

.sent-stat {
  font-size: 22rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.sent-stat image {
  width: 24rpx;
  height: 24rpx;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* Load more */
.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #bbb;
}

.load-more.done {
  color: #ddd;
}
