// 格式化数字：万/亿缩写
function formatCount(num) {
  if (num === null || num === undefined) return '0';
  num = +num;
  if (isNaN(num) || num < 0) return '0';
  if (num < 10000) return '' + num;
  if (num < 100000000) {
    var w = num / 10000;
    // 整数不补 .0
    return (w === Math.floor(w) ? '' + w : '' + w.toFixed(1)) + '万';
  }
  var y = num / 100000000;
  return (y === Math.floor(y) ? '' + y : '' + y.toFixed(1)) + '亿';
}

module.exports = {
  formatCount: formatCount
};
