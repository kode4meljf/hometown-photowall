<!-- pages/upload/upload.wxml -->
<view class="upload-page">
  <!-- 顶部大图预览区 -->
  <view class="preview-area" bindtap="previewFullScreen">
    <image
      wx:if="{{imageList.length > 0}}"
      class="preview-image"
      src="{{imageList[currentIndex]}}"
      mode="aspectFit"
    />
    <view wx:else class="preview-placeholder">
      <text class="placeholder-icon">📷</text>
      <text class="placeholder-text">点击下方添加图片</text>
    </view>
    <view class="image-counter" wx:if="{{imageList.length > 1}}">
      <text>{{currentIndex + 1}}/{{imageList.length}}</text>
    </view>
  </view>

  <!-- 缩略图栏 -->
  <view class="thumbnail-bar {{imageList.length > 0 ? 'has-images' : ''}}">
    <!-- 缩略图滚动区 -->
    <scroll-view
      class="thumbnail-scroll {{imageList.length > 0 ? 'expand' : ''}}"
      scroll-x
    >
      <view class="thumbnail-list {{isOverflow ? 'overflow' : ''}}">
        <view
          class="thumbnail-item {{currentIndex === index ? 'selected' : ''}}"
          wx:for="{{imageList}}"
          wx:key="index"
          bindtap="selectImage"
          data-index="{{index}}"
        >
          <image class="thumbnail-image" src="{{item}}" mode="aspectFill" />
          <view class="delete-btn" catchtap="deleteImage" data-index="{{index}}">×</view>
        </view>
      </view>
    </scroll-view>

    <!-- 添加按钮：作为 bar 的独立子元素，不参与图片滚动 -->
    <view
      class="thumbnail-add {{imageList.length >= 9 ? 'disabled' : ''}}"
      bindtap="chooseImage"
      wx:if="{{imageList.length < 9}}"
    >
      <text class="add-icon">+</text>
    </view>

    <!-- 右侧羽化遮罩 -->
    <view class="scroll-fade-right" wx:if="{{isOverflow}}"></view>
  </view>

  <!-- 表单区域 -->
  <scroll-view class="form-scroll" scroll-y>
    <view class="form-section">
      <!-- 标题/描述 -->
      <view class="form-item">
        <input
          class="title-input {{highlightTitle ? 'highlight' : ''}}"
          placeholder="添加标题"
          placeholder-class="placeholder"
          value="{{form.title}}"
          bindinput="onTitleInput"
          focus="{{focusTitle}}"
        />
      </view>

      <view class="form-item">
        <textarea
          class="desc-input"
          placeholder="添加作品描述…"
          placeholder-class="placeholder"
          value="{{form.description}}"
          bindinput="onDescInput"
          maxlength="200"
        />
      </view>

      <!-- 地点选择 -->
      <view class="location-section">
        <view class="location-header" bindtap="toggleLocationExpand">
          <text class="location-icon">📍</text>
          <text class="location-label">{{form.location || '你在哪里'}}</text>
          <text class="location-arrow {{locationExpanded ? 'expanded' : ''}}">›</text>
        </view>
        <view class="location-tags {{locationExpanded ? 'expanded' : ''}}" wx:if="{{locations.length > 0}}">
          <view
            class="location-tag {{form.location === item ? 'active' : ''}}"
            wx:for="{{locations}}"
            wx:key="index"
            bindtap="selectLocation"
            data-location="{{item}}"
          >
            <text>{{item}}</text>
          </view>
          <!-- 自定义地点输入 -->
          <input
            class="custom-location-input"
            placeholder="自定义"
            placeholder-class="placeholder"
            value="{{customLocation}}"
            bindinput="onCustomLocationInput"
            bindconfirm="confirmCustomLocation"
          />
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部发布按钮 -->
  <view class="submit-bar">
    <view class="submit-btn {{submitting ? 'submitting' : ''}}" bindtap="{{submitting ? '' : 'handleSubmit'}}">
      <text>{{submitting ? '发布中…' : '发布照片'}}</text>
    </view>
  </view>
</view>
