<!-- pages/profile/profile.wxml -->
<view class="profile-page">
  <!-- 顶部用户信息 - 白色卡片，内容垂直居中 -->
  <view class="user-header">
    <!-- 头像 -->
    <view class="avatar avatar-center" bindtap="onAvatarTap">
      <image class="avatar-img" src="{{userInfo.avatar || '/assets/icons/default-avatar.png'}}{{userInfo.avatarUpdateTime ? '?v=' + userInfo.avatarUpdateTime : ''}}" mode="aspectFill" />
    </view>
    <!-- 昵称 + 副标题 + 地区 -->
    <text class="nickname">{{userInfo.nickname || '未登录'}}</text>
    <view class="profile-region-group" wx:if="{{userInfo.regionDisplay || userInfo.genderDisplay}}">
      <text class="profile-region-tag" wx:if="{{userInfo.regionDisplay}}">{{userInfo.regionDisplay}}</text>
      <text class="profile-region-tag gender-tag" wx:if="{{userInfo.genderDisplay}}">{{userInfo.genderDisplay}}</text>
    </view>
    <!-- bio + 标签 -->
    <view class="profile-bio-tags" wx:if="{{userInfo.bio || (userInfo.tags && userInfo.tags.length > 0)}}">
      <text class="profile-bio" wx:if="{{userInfo.bio}}">「 {{userInfo.bio}} 」</text>
      <view class="profile-tags" wx:if="{{userInfo.tags && userInfo.tags.length > 0}}">
        <text class="profile-tag {{index === 0 ? 'profile-tag-first' : ''}}" wx:for="{{userInfo.tags}}" wx:key="this">{{item}}</text>
      </view>
    </view>

    <!-- 三栏统计 -->
    <view class="stats-row">
      <view class="stat-item" bindtap="switchTab" data-tab="works">
        <text class="stat-num">{{worksCount || 0}}</text>
        <text class="stat-label">作品</text>
      </view>
      <view class="stat-item" bindtap="switchTab" data-tab="liked">
        <text class="stat-num">{{likedCount || 0}}</text>
        <text class="stat-label">赞过</text>
      </view>
      <view class="stat-item" bindtap="freePoints">
        <text class="stat-num">{{userInfo.points || 0}}</text>
        <text class="stat-label">积分</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-btns">
      <view class="action-btn action-btn-primary" bindtap="goToEditProfile">编辑资料</view>
      <view class="action-btn" hover-class="action-btn-press" bindtap="onSettingsTap">设置</view>
    </view>
  </view>

  <!-- 常用功能3宫格 -->
  <view class="func-section">
    <view class="section-label">常用功能</view>
    <view class="func-row">
      <view class="func-item" hover-class="func-item-press" bindtap="onFuncTap" data-func="comments">
        <view class="func-icon">
          <image src="/assets/icons/icon-comments.svg" mode="aspectFit" />
        </view>
        <text class="func-text">我的评论</text>
      </view>
      <view class="func-item" hover-class="func-item-press" bindtap="onFuncTap" data-func="signin">
        <view class="func-icon">
          <image src="/assets/icons/icon-signin.svg" mode="aspectFit" />
        </view>
        <text class="func-text">每日签到</text>
      </view>
      <view class="func-item" hover-class="func-item-press" bindtap="onFuncTap" data-func="stats">
        <view class="func-icon">
          <image src="/assets/icons/icon-stats.svg" mode="aspectFit" />
        </view>
        <text class="func-text">数据统计</text>
      </view>
    </view>
  </view>

  <!-- 标签切换区域 -->
  <view class="tabs-container">
    <view class="tabs">
      <!-- 作品 Tab：点击区分切换 Tab 和弹窗；赞过 Tab：直接切换 -->
      <view class="tab {{activeTab === 'works' ? 'active' : ''}}" catchtap="onWorksFilterTap" data-tab="works" id="works-tab">
        作品
        <text class="count" wx:if="{{worksCount > 0}}">{{worksCount}}</text>
        <view class="tab-arrow {{worksDropdownOpen ? 'arrow-up' : ''}}"></view>
      </view>
      <view class="tab {{activeTab === 'liked' ? 'active' : ''}}" catchtap="switchTab" data-tab="liked">
        赞过
        <text class="count" wx:if="{{likedCount > 0}}">{{likedCount}}</text>
      </view>
    </view>
  </view>

  <!-- 点击遮罩关闭弹窗，不冒泡不导航 -->
  <view class="works-dropdown-mask" wx:if="{{worksDropdownOpen}}" catchtap="closeWorksDropdown"></view>

    <view class="works-dropdown-wrap" wx:if="{{worksDropdownOpen}}" style="top:{{dropdownTop}}px;left:{{dropdownLeft}}px;">
    <view class="dropdown-arrow" style="left:{{triangleLeft}}rpx"></view>
    <view class="works-dropdown">
      <view class="dropdown-item {{worksFilter === 'all' ? 'active' : ''}}" bindtap="onWorksFilterChange" data-filter="all">
        <view class="dropdown-dot"></view>
        <text class="dropdown-label">全部作品</text>
        <view class="dropdown-count {{worksFilter === 'all' ? 'active' : ''}}">{{worksCount || 0}}</view>
      </view>
      <view class="dropdown-item {{worksFilter === 'hidden' ? 'active' : ''}}" bindtap="onWorksFilterChange" data-filter="hidden">
        <view class="dropdown-dot"></view>
        <text class="dropdown-label">已隐藏</text>
        <view class="dropdown-count {{worksFilter === 'hidden' ? 'active' : ''}}">{{hiddenCount || 0}}</view>
      </view>
    </view>
  </view>

  <!-- 内容区域 - Swiper 实现左右滑动切换 -->
  <swiper
    class="content-swiper"
    current="{{currentTabIndex}}"
    bindchange="onSwiperChange"
    duration="300"
    acceleration
  >
    <!-- 作品页 -->
    <swiper-item class="swiper-item">
      <scroll-view scroll-y class="photo-scroll" bindscrolltolower="loadMoreWorks" enhanced enable-flex>
        <view class="photo-list" wx:if="{{works.length > 0}}">
          <view 
            class="photo-card" 
            wx:for="{{works}}" 
            wx:key="id"
            bindtap="goToDetail"
            data-id="{{item.id}}"
          >
            <image class="photo-image" src="{{item.imageUrl}}" mode="aspectFill" lazy-load />
            <view class="photo-overlay">
              <view class="photo-stats">
                <image src="/assets/icons/icon-views.svg" class="views-icon" mode="aspectFit" />
                <text class="views-count">{{item.views || 0}}</text>
              </view>
            </view>
            <!-- 右上角操作按钮（仅作品 tab 显示） -->
            <view 
              class="photo-more-btn" 
              catchtap="openPhotoAction" 
              data-id="{{item.id}}"
              data-title="{{item.title}}"
              data-hidden="{{item.hidden}}"
            >⋮</view>
          </view>
        </view>
        <view class="empty-state" wx:if="{{works.length === 0 && !loading}}">
          <image class="empty-icon-image" src="/assets/icons/camera-empty.png" mode="aspectFit" />
          <text class="empty-text" wx:if="{{isLoggedIn}}">暂无作品</text>
          <text class="empty-text" wx:if="{{!isLoggedIn}}">登录后查看更多内容</text>
          <view class="empty-btn" wx:if="{{isLoggedIn}}" bindtap="goToUpload">去上传照片</view>
          <view class="empty-btn" wx:if="{{!isLoggedIn}}" bindtap="goToLogin">登录</view>
        </view>
        <view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>
      </scroll-view>
    </swiper-item>

    <!-- 赞过页 -->
    <swiper-item class="swiper-item">
      <scroll-view scroll-y class="photo-scroll" bindscrolltolower="loadMoreLiked" enhanced enable-flex>
        <view class="photo-list" wx:if="{{liked.length > 0}}">
          <view 
            class="photo-card" 
            wx:for="{{liked}}" 
            wx:key="id"
            bindtap="goToDetail"
            data-id="{{item.id}}"
          >
            <image class="photo-image" src="{{item.imageUrl}}" mode="aspectFill" lazy-load />
            <view class="photo-overlay">
              <view class="photo-stats">
                <image src="/assets/icons/icon-views.svg" class="views-icon" mode="aspectFit" />
                <text class="views-count">{{item.views || 0}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-state" wx:if="{{liked.length === 0 && !loading}}">
          <image class="empty-icon-image" src="/assets/icons/liked-empty.png" mode="aspectFit" />
          <text class="empty-text empty-text-dark" wx:if="{{isLoggedIn}}">暂无赞过的作品</text>
          <text class="empty-text" wx:if="{{!isLoggedIn}}">登录后查看更多内容</text>
          <view class="empty-btn" wx:if="{{isLoggedIn}}" bindtap="goToHome">去首页看看</view>
          <view class="empty-btn" wx:if="{{!isLoggedIn}}" bindtap="goToLogin">登录</view>
        </view>
        <view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>
      </scroll-view>
    </swiper-item>
  </swiper>



  <!-- 作品操作底部弹窗 - 微信原生 ActionSheet 风格 -->
  <view class="avatar-modal" wx:if="{{showPhotoAction}}" bindtap="hidePhotoAction">
    <view class="avatar-modal-content" catchtap="stopPropagation">
      <!-- 选项组 -->
      <view class="modal-options-group">
        <view class="modal-option" bindtap="editPhotoTitle">编辑标题</view>
        <view class="modal-option" bindtap="toggleHidePost">{{currentPhotoHidden ? '显示作品' : '隐藏作品'}}</view>
        <view class="modal-option modal-option-danger" bindtap="deletePost">删除</view>
      </view>
      <!-- 取消按钮 - 独立卡片 -->
      <view class="modal-cancel" bindtap="hidePhotoAction">取消</view>
    </view>
  </view>
</view>