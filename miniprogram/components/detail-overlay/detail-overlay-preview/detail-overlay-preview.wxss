/* ========== 全屏预览 ========== */
.preview-layer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  z-index: var(--z-detail-preview);
  display: flex;
  flex-direction: column;
  transition: background-color 280ms ease;
}

.preview-layer.bg-black {
  background: #121212;
}

.preview-layer.bg-transparent {
  background: transparent;
}

.preview-drag-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
}

.preview-image-area {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: auto;
}

.preview-image-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  transform-origin: 0 0;
  will-change: transform;
  pointer-events: auto;
}

.preview-image-wrapper.preview-dismiss-dragging {
  transform-origin: center center;
}

.preview-image-wrapper.animating-enter {
  transition: transform 350ms cubic-bezier(0.34, 1.56, 0.64, 1), opacity 80ms linear;
}

.preview-image-wrapper.animating-exit {
  transition: transform 280ms cubic-bezier(0.34, 1.56, 0.64, 1), opacity 280ms ease;
}

.preview-image-wrapper.animating {
  transition: transform 300ms ease-out, opacity 80ms linear;
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.preview-swiper {
  width: 100%;
  height: 100%;
}

.preview-touch-catcher {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
}

.preview-progress-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: calc(84rpx + env(safe-area-inset-bottom) + 16rpx);
  display: flex;
  gap: 4px;
  padding: 0 24rpx;
  pointer-events: none;
  z-index: 10;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.preview-progress-bar.progress-show {
  opacity: 1;
}

.preview-progress-segment {
  flex: 1;
  height: 3px;
  border-radius: 1.5px;
}

.preview-progress-segment.done {
  background: rgba(255, 255, 255, 0.85);
}

.preview-progress-segment.todo {
  background: rgba(255, 255, 255, 0.15);
}

.preview-index-badge {
  position: absolute;
  top: 60rpx;
  right: 32rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
  z-index: 3;
}

.preview-index-badge.badge-show {
  opacity: 1;
}

.preview-badge-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
}

.like-animation {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0);
  font-size: 120rpx;
  opacity: 0;
  pointer-events: none;
  z-index: var(--z-detail-like);
}

.like-animation.show {
  animation: overlayLikePop 0.6s ease-out forwards;
}

@keyframes overlayLikePop {
  0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
  30% { transform: translate(-50%, -50%) scale(1.3); opacity: 1; }
  60% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
}

.preview-bottom-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  height: calc(84rpx + env(safe-area-inset-bottom));
  background: #000;
}

.preview-actions {
  position: relative;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.preview-actions.fade-in {
  opacity: 1;
}

.preview-action-item {
  position: absolute;
  top: 40%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
}

.preview-close-btn {
  left: 64rpx;
}

.preview-download-btn {
  right: 64rpx;
}

.preview-action-icon {
  font-size: 48rpx;
  color: #fff;
}
