<!-- pages/detail/detail.wxml -->
<wxs src="../../utils/filters.wxs" module="f" />
<!-- 外层容器：flex列，撑满全屏 -->
<view class="detail-shell {{yPageVisible ? '' : 'y-hidden'}}" wx:if="{{post}}">

  <!-- 顶部：返回 + 头像 + 昵称 -->
  <view class="header" style="padding-top:{{headerPaddingTop}}px;">
    <view class="header-left">
      <view class="back-btn" bindtap="goBack"><text>‹</text></view>
      <image class="author-avatar" src="{{post.authorAvatar || '/assets/icons/default-avatar.png'}}" mode="aspectFill" />
      <text class="author-name">{{post.author}}</text>
    </view>
  </view>

  <!-- 可滚动内容区 -->
  <scroll-view class="detail-scroll" scroll-y bindscroll="onCommentScroll">
    <!-- 图片区域：多图轮播 / 单图展示 -->
    <view class="image-section {{isPreviewMode ? 'y-hidden' : ''}}" style="{{photoStyle}}">
      <swiper
        class="photo-swiper"
        current="{{currentPhotoIndex}}"
        bindchange="onSwiperChange"
        duration="300"
        circular="{{false}}"
      >
        <swiper-item wx:for="{{post.photos}}" wx:key="order">
          <image
            class="photo-image {{isPreviewMode ? 'y-hidden' : ''}}"
            src="{{item.imageUrl}}"
            mode="{{photoMode}}"
            bindload="onPhotoLoad"
            bindtap="enterPreview"
            data-index="{{index}}"
          />
        </swiper-item>
      </swiper>
      <!-- 全宽线段进度条 -->
      <view class="progress-bar" wx:if="{{post.photos.length > 1}}">
        <view
          wx:for="{{post.photos}}"
          wx:key="order"
          class="progress-segment {{index <= currentPhotoIndex ? 'done' : 'todo'}}"
        ></view>
      </view>
      <!-- 右上角文字指示器（滑动时渐现） -->
      <view class="photo-index-badge {{indexBadgeVisible ? 'badge-show' : ''}}" wx:if="{{post.photos.length > 1}}">
        <text class="badge-text">{{currentPhotoIndex + 1}}/{{post.photos.length}}</text>
      </view>
    </view>

    <!-- 图片描述 -->
    <view class="content-section">
      <text class="description" wx:if="{{post.titleDesc}}">{{post.titleDesc}}</text>
      <text class="date">{{post.date}}</text>
    </view>

    <view class="divider"></view>

    <view class="comment-count">
      <text>共 {{post.commentsCount || post.comments.length}} 条评论</text>
    </view>

    <!-- 评论列表 -->
    <view class="comment-list">
      <view class="comment-item" wx:for="{{post.comments}}" wx:key="id">
        <image class="comment-avatar" src="{{item.authorAvatar || '/assets/icons/default-avatar.png'}}" mode="aspectFill" />
        <view class="comment-content">
          <text class="comment-author">{{item.author}}</text>
          <text class="comment-text">{{item.content}}</text>
          <text class="comment-time">{{item.time}}</text>
        </view>
      </view>
      <view class="load-more" wx:if="{{commentsLoading}}">
        <view class="loading-dots"><view class="dot dot1"></view><view class="dot dot2"></view><view class="dot dot3"></view></view>
      </view>
      <view class="load-more load-more-done" wx:if="{{!hasMoreComments && post.comments.length > 0}}">
        <text class="no-more-text">没有更多了</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部操作栏：抖音图文详情页风格 -->
  <view class="bottom-bar">
    <!-- 输入框：左侧笔图标 + 占位文字 -->
    <view class="input-area" bindtap="focusCommentInput">
      <image class="input-pen-icon" src="/assets/icons/pen-icon.png" mode="aspectFit" />
      <text class="input-placeholder">说点什么...</text>
    </view>

    <!-- 操作按钮组 -->
    <view class="action-buttons">
      <!-- 点赞：图标 + 数字，点赞后数字变红 -->
      <view class="action-item {{post.liked ? 'liked' : ''}}" bindtap="handleLike">
        <image
          class="action-icon-img"
          src="{{post.liked ? '/assets/icons/like-active.png' : '/assets/icons/like.png'}}"
          mode="aspectFit"
        />
        <text class="action-num {{post.liked ? 'liked' : ''}}">{{f.formatCount(post.likes)}}</text>
      </view>

      <!-- 评论 -->
      <view class="action-item" bindtap="focusCommentInput">
        <image class="action-icon-img" src="/assets/icons/comment.png" mode="aspectFit" />
        <text class="action-num">{{f.formatCount(post.comments.length)}}</text>
      </view>

      <!-- 分享 -->
      <view class="action-item" bindtap="handleShare">
        <image class="action-icon-img" src="/assets/icons/share.png" mode="aspectFit" />
        <text class="action-num">{{f.formatCount(post.shares || 0)}}</text>
      </view>
    </view>
  </view>

</view>

<!-- 评论输入弹窗 -->
<view class="comment-modal" wx:if="{{showCommentInput}}">
  <view class="comment-modal-mask" bindtap="hideCommentInput"></view>
  <view class="comment-modal-content">
    <input class="comment-input-field" placeholder="写下你的评论..." value="{{commentContent}}" bindinput="onCommentInput" focus="{{showCommentInput}}" confirm-type="send" bindconfirm="submitComment" />
    <view class="comment-send-btn" bindtap="submitComment">发送</view>
  </view>
</view>

<!-- 全屏预览层：FLIP动画 + 背景渐变 -->
<view
  class="preview-layer {{previewBgBlack ? 'bg-black' : 'bg-transparent'}}"
  wx:if="{{isPreviewMode}}"
  bindtouchstart="onPreviewTouchStart"
  bindtouchmove="onPreviewTouchMove"
  bindtouchend="onPreviewTouchEnd"
>
  <!-- 图片区域 -->
  <view class="preview-image-area">
    <!-- 下拉遮罩：下滑时渐透明 -->
    <view class="preview-drag-overlay" style="opacity: {{overlayOpacity}};"></view>
    <!-- 动画容器：CSS transition 驱动，transform-origin: 0 0 -->
    <view class="preview-image-wrapper {{previewAnimClass}}" style="transform: {{previewTransform}}; opacity: {{previewOpacity !== 0 ? 1 : 0}};">
      <swiper
        class="preview-swiper"
        current="{{currentPhotoIndex}}"
        bindchange="onPreviewSwiperChange"
        duration="300"
      >
        <swiper-item wx:for="{{post.photos}}" wx:key="order">
          <image
            class="preview-image"
            src="{{item.imageUrl}}"
            mode="aspectFit"
          />
        </swiper-item>
      </swiper>
      <!-- 预览模式全宽线段进度条 -->
      <view class="preview-progress-bar" wx:if="{{post.photos.length > 1}}">
        <view
          wx:for="{{post.photos}}"
          wx:key="order"
          class="preview-progress-segment {{index <= currentPhotoIndex ? 'done' : 'todo'}}"
        ></view>
      </view>
      <!-- 预览模式右上角文字指示器 -->
      <view class="preview-index-badge {{indexBadgeVisible ? 'badge-show' : ''}}" wx:if="{{post.photos.length > 1}}">
        <text class="preview-badge-text">{{currentPhotoIndex + 1}}/{{post.photos.length}}</text>
      </view>
    </view>
  </view>

  <!-- 点赞动画 -->
  <view class="like-animation {{showLikeAnim ? 'show' : ''}}" wx:if="{{showLikeAnim}}">
    <text>❤️</text>
  </view>

  <!-- 底部固定黑色操作栏 -->
  <view class="preview-bottom-bar">
    <view class="preview-actions {{bottomBarVisible ? 'fade-in' : ''}}">
      <view class="preview-action-item" catchtap="exitPreview">
        <text class="preview-action-icon">×</text>
      </view>
      <view class="preview-action-item" catchtap="downloadImage">
        <text class="preview-action-icon">↓</text>
      </view>
    </view>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-page" wx:if="{{loading}}"><text>加载中...</text></view>
