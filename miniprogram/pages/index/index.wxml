<!-- 首页 - 新设计 -->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索标题或描述" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearchConfirm"
      />
      <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">
        <text class="clear-icon">×</text>
      </view>
    </view>
  </view>

  <!-- 筛选标签栏 -->
  <view class="filter-bar">
    <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="filter-content">
        <!-- 排序标签 -->
        <view class="filter-group">
          <view 
            class="filter-tag {{sortType === 'latest' ? 'active' : ''}}" 
            bindtap="onSortTap"
            data-sort="latest"
          >
            最新
          </view>
          <view 
            class="filter-tag {{sortType === 'likes' ? 'active' : ''}}" 
            bindtap="onSortTap"
            data-sort="likes"
          >
            最多赞
          </view>
        </view>
        
        <!-- 分隔线 -->
        <view class="filter-divider"></view>
        
        <!-- 地点标签 -->
        <view class="filter-group">
          <view 
            wx:for="{{locations}}" 
            wx:key="*this"
            class="filter-tag {{selectedLocation === item ? 'active' : ''}}"
            bindtap="onLocationTap"
            data-location="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 瀑布流内容 -->
  <scroll-view 
    class="waterfall-scroll" 
    scroll-y 
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="loadMore"
    bindrefresherrefresh="onRefresh"
    refresher-enabled="{{true}}"
    refresher-triggered="{{isRefreshing}}"
  >
    <view class="waterfall-container">
      <!-- 左列 -->
      <view class="waterfall-column" id="left-column">
        <view 
          wx:for="{{leftPosts}}" 
          wx:key="id"
          class="photo-card"
          bindtap="goToDetail"
          data-id="{{item.id}}"
        >
          <view class="card-image-wrapper" style="height: {{item.cardHeight}}px;">
            <image 
              class="card-image" 
              src="{{item.imageUrl}}" 
              mode="aspectFill"
              lazy-load
            />
            <view class="views-badge">
              
              <text class="views-text">{{item.views}}</text>
            </view>
          </view>
          <view class="card-content">
            <text class="card-title" wx:if="{{item.title}}">{{item.title}}</text>
            <text class="card-desc" wx:if="{{item.description}}">{{item.description}}</text>
            <view class="card-footer">
              <view class="author-info">
                <image class="author-avatar" src="{{item.authorAvatar || '/assets/icons/default-avatar.png'}}" mode="aspectFill"/>
                <view class="author-meta">
                  <text class="author-name">{{item.author || '匿名用户'}}</text>
                  <text class="post-date">{{item._formattedDate}}</text>
                </view>
              </view>
              <view class="like-info {{item.liked ? 'liked' : ''}}" catchtap="onLikeTap" data-id="{{item.id}}" data-index="{{index}}" data-column="left">
                <image class="like-icon" src="{{item.liked ? '/assets/icons/like-active.png' : '/assets/icons/like.png'}}" mode="aspectFit"/>
                <text class="like-count">{{item.likes || 0}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 右列 -->
      <view class="waterfall-column" id="right-column">
        <view 
          wx:for="{{rightPosts}}" 
          wx:key="id"
          class="photo-card"
          bindtap="goToDetail"
          data-id="{{item.id}}"
        >
          <view class="card-image-wrapper" style="height: {{item.cardHeight}}px;">
            <image 
              class="card-image" 
              src="{{item.imageUrl}}" 
              mode="aspectFill"
              lazy-load
            />
            <view class="views-badge">
              
              <text class="views-text">{{item.views}}</text>
            </view>
          </view>
          <view class="card-content">
            <text class="card-title" wx:if="{{item.title}}">{{item.title}}</text>
            <text class="card-desc" wx:if="{{item.description}}">{{item.description}}</text>
            <view class="card-footer">
              <view class="author-info">
                <image class="author-avatar" src="{{item.authorAvatar || '/assets/icons/default-avatar.png'}}" mode="aspectFill"/>
                <view class="author-meta">
                  <text class="author-name">{{item.author || '匿名用户'}}</text>
                  <text class="post-date">{{item._formattedDate}}</text>
                </view>
              </view>
              <view class="like-info {{item.liked ? 'liked' : ''}}" catchtap="onLikeTap" data-id="{{item.id}}" data-index="{{index}}" data-column="right">
                <image class="like-icon" src="{{item.liked ? '/assets/icons/like-active.png' : '/assets/icons/like.png'}}" mode="aspectFit"/>
                <text class="like-count">{{item.likes || 0}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{isLoading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && posts.length > 0}}">
      <text>没有更多了</text>
    </view>
    <view class="empty-state" wx:if="{{!isLoading && posts.length === 0}}">
      <image class="empty-icon" src="/assets/icons/empty-photos.png" mode="aspectFit"/>
      <text class="empty-text">暂无内容</text>
    </view>
    
    <!-- 底部留白（给自定义 TabBar） -->
    <view class="tabbar-placeholder"></view>
  </scroll-view>

  <!-- 自定义 TabBar -->
  <view class="custom-tabbar">
    <view class="tabbar-item {{activeTab === 'home' ? 'active' : ''}}" bindtap="switchTab" data-tab="home">
      <image class="tabbar-icon" src="{{activeTab === 'home' ? '/assets/icons/home-active.png' : '/assets/icons/home.png'}}" mode="aspectFit"/>
      <text class="tabbar-text">首页</text>
    </view>
    <view class="tabbar-center" bindtap="goToUpload">
      <view class="publish-btn">
        <text class="publish-icon">+</text>
      </view>
    </view>
    <view class="tabbar-item {{activeTab === 'profile' ? 'active' : ''}}" bindtap="switchTab" data-tab="profile">
      <image class="tabbar-icon" src="{{activeTab === 'profile' ? '/assets/icons/profile-active.png' : '/assets/icons/profile.png'}}" mode="aspectFit"/>
      <text class="tabbar-text">我的</text>
    </view>
  </view>
</view>
