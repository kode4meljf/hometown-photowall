<!-- pages/upload/upload.wxml -->
<view class="upload-page">
  <view class="form-section">
    <!-- 图片上传 -->
    <view class="image-upload" bindtap="chooseImage">
      <image wx:if="{{imageUrl}}" class="preview-image" src="{{imageUrl}}" mode="aspectFit" />
      <view wx:else class="upload-placeholder">
        <text class="upload-icon">📷</text>
        <text class="upload-text">点击选择图片</text>
      </view>
    </view>

    <!-- 表单 -->
    <view class="form">
      <view class="form-item">
        <text class="label">标题 *</text>
        <input class="input" placeholder="请输入照片标题" value="{{form.title}}" bindinput="onTitleInput" />
      </view>

      <view class="form-item">
        <text class="label">描述</text>
        <textarea class="textarea" placeholder="记录这张照片的故事..." value="{{form.description}}" bindinput="onDescInput" maxlength="200" />
      </view>

      <view class="form-item">
        <text class="label">地点</text>
        <picker mode="selector" range="{{locationOptions}}" bindchange="onLocationSelect">
          <view class="picker">
            <text>{{form.location || '点击选择或自定义地点'}}</text>
            <text class="arrow">▼</text>
          </view>
        </picker>
        <input 
          class="input custom-input" 
          placeholder="自定义地点" 
          value="{{form.location}}" 
          bindinput="onLocationInput" 
        />
        <text class="hint" wx:if="{{locations.length > 0}}">已有地点：{{locations.join('、')}}</text>
      </view>

      <view class="form-item">
        <text class="label">分类</text>
        <picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange">
          <view class="picker">
            <text>{{form.category || '请选择分类'}}</text>
            <text class="arrow">▼</text>
          </view>
        </picker>
      </view>

      <button class="submit-btn" bindtap="handleSubmit" loading="{{submitting}}">
        发布照片
      </button>
    </view>
  </view>
</view>