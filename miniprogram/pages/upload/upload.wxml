<!-- pages/upload/upload.wxml -->
<view class="upload-page">
  <!-- 顶部大图预览区 -->
  <view class="preview-area" bindtap="previewFullScreen">
    <image
      wx:if="{{imageList.length > 0}}"
      class="preview-image"
      src="{{imageList[currentIndex]}}"
      mode="aspectFit"
    />
    <view wx:else class="preview-placeholder">
      <image class="placeholder-icon" src="/assets/icons/empty-photos.png" mode="aspectFit" />
      <text class="placeholder-text">点击下方添加图片</text>
    </view>
    <!-- 删除按钮：移到预览区右上角 -->
    <view class="preview-delete-btn" wx:if="{{imageList.length > 0}}" catchtap="deleteCurrentImage">×</view>
    <view class="image-counter" wx:if="{{imageList.length > 1}}">
      <text>{{currentIndex + 1}}/{{imageList.length}}</text>
    </view>
  </view>

  <!-- 缩略图栏：缩略图组 + 按钮一行 -->
  <view class="thumbnail-bar">
    <view class="thumbnail-scroll {{isOverflow ? 'overflow' : ''}}" style="width: {{scrollWidth ? scrollWidth + 'px' : '100%'}}">
      <view class="thumbnail-row">
        <view
          class="thumbnail-item {{currentIndex === index ? 'selected' : ''}}"
          wx:for="{{imageList}}"
          wx:key="index"
          bindtap="selectImage"
          data-index="{{index}}"
        >
          <image class="thumbnail-image" src="{{item}}" mode="aspectFill" />
          <view class="delete-btn" catchtap="deleteImage" data-index="{{index}}">×</view>
        </view>
        <!-- 添加按钮：固定在 row 最右侧 -->
        <view class="thumbnail-add" bindtap="chooseImage">
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 表单区域 -->
  <scroll-view class="form-scroll" scroll-y>
    <view class="form-section">
      <!-- 标题/描述 -->
      <view class="form-item">
        <input
          class="title-input {{highlightTitle ? 'highlight' : ''}}"
          placeholder="添加标题"
          placeholder-class="placeholder"
          value="{{form.title}}"
          bindinput="onTitleInput"
          focus="{{focusTitle}}"
        />
      </view>

      <view class="form-item">
        <textarea
          class="desc-input"
          placeholder="添加作品描述…"
          placeholder-class="placeholder"
          value="{{form.description}}"
          bindinput="onDescInput"
          maxlength="200"
        />
      </view>

      <!-- 地点选择 -->
      <view class="location-section">
        <!-- 标题行：图标+文字 + 选中tag（选中时显示在右侧） -->
        <view class="location-header {{form.location ? 'has-location' : ''}}">
          <image class="location-icon" src="/assets/icons/location.png" mode="aspectFit" />
          <text class="location-label">{{form.location || '你在哪里'}}</text>
          <!-- X 清除按钮：选中后靠屏幕最右 -->
          <view class="location-clear-btn" wx:if="{{form.location}}" bindtap="clearLocation">×</view>
        </view>
        <!-- 可选地点列表（未选中时显示） -->
        <view class="location-tags" wx:if="{{!form.location}}">
          <!-- 动态地点（数据库已有） -->
          <view
            class="location-tag"
            wx:for="{{locations}}"
            wx:key="index"
            bindtap="selectLocation"
            data-location="{{item}}"
          >
            <text>{{item}}</text>
          </view>
          <!-- 自定义地点输入 -->
          <input
            class="custom-location-input"
            placeholder="自定义"
            placeholder-class="placeholder"
            value="{{customLocation}}"
            bindinput="onCustomLocationInput"
            bindconfirm="confirmCustomLocation"
          />
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部发布按钮 -->
  <view class="submit-bar">
    <view class="submit-btn {{submitting ? 'submitting' : ''}}" bindtap="{{submitting ? '' : 'handleSubmit'}}">
      <text>{{submitting ? '发布中…' : '发布照片'}}</text>
    </view>
  </view>
</view>
