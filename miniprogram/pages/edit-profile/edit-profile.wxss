/* pages/edit-profile/edit-profile.wxss */

/* === 页面容器 === */
.edit-page {
  min-height: 100vh;
  background: #f8f8f8;
  padding-top: 24rpx;
  padding-bottom: 140rpx;
}

/* === 导航栏 === */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background: #ffffff;
  display: flex;
  align-items: flex-end;  /* 内容底部对齐 */
  justify-content: space-between;
  padding: 0 32rpx;
  padding-bottom: 0;
  border-bottom: 1rpx solid #e5e5e5;
  z-index: 100;
}

.nav-back {
  font-size: 48rpx;
  color: #1b1b1b;
  width: 64rpx;
  height: 88rpx;
  display: flex;
  align-items: flex-end;
  padding-bottom: 8rpx;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1b1b1b;
  height: 88rpx;
  display: flex;
  align-items: flex-end;
  padding-bottom: 8rpx;
}

.nav-placeholder {
  width: 64rpx;
}

/* === 页面内容 === */
.page-content {
  padding: 24rpx 24rpx 0;
}

/* === 头像卡片 === */
.avatar-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.avatar-btn {
  position: relative;
  width: 120rpx !important;
  height: 120rpx !important;
  border-radius: 50% !important;
  background: #f0f0f0;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-btn::after { display: none; }

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: block;
  object-fit: cover;
}

.avatar-hint {
  font-size: 24rpx;
  color: #999;
}

/* === 表单卡片 === */
.form-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.form-card-header {
  padding: 28rpx 32rpx 0;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.form-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1b1b1b;
}

.form-card-hint {
  font-size: 24rpx;
  color: #999;
}

/* === 表单行 === */
.form-row {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  min-height: 104rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #1b1b1b;
  width: 96rpx;
  flex-shrink: 0;
}

.form-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.form-value {
  font-size: 30rpx;
  color: #1b1b1b;
  text-align: right;
}

.form-value.placeholder,
.region-empty {
  color: #ccc;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #1b1b1b;
  background: transparent;
  border: none;
  outline: none;
  height: 104rpx;
}

.form-input::placeholder {
  color: #ccc;
}

/* === 性别 === */
.gender-row {
  flex: 1;
  display: flex;
  gap: 40rpx;
  justify-content: flex-end;
}

.gender-opt {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  color: #999;
}

.gender-opt.active {
  color: #1b1b1b;
  font-weight: 600;
}

.radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border-color 0.15s;
}

.gender-opt.active .radio {
  border-color: #1b1b1b;
}

.radio-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #1b1b1b;
}

/* === 箭头 === */
.arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* === 地区选择器 === */
.region-picker {
  flex: 1;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
}
.region-picker::after { display: none; }

/* === 简介 === */
.form-row-bio {
  flex-direction: column;
  align-items: flex-start;
  padding: 20rpx 32rpx 24rpx;
  min-height: unset;
}

.bio-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.char-count {
  font-size: 24rpx;
  color: #ccc;
}

.form-textarea {
  width: 100%;
  font-size: 30rpx;
  color: #1b1b1b;
  background: transparent;
  border: none;
  outline: none;
  resize: none;
  line-height: 1.6;
  min-height: 120rpx;
}

.form-textarea::placeholder {
  color: #ccc;
}

/* === 兴趣标签 === */
.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 32rpx 28rpx;
}

.tag {
  padding: 12rpx 28rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  background: #ffffff;
  color: #1b1b1b;
  border: 1rpx dashed #ccc;
  transition: all 0.15s;
}

.tag.active {
  background: #f5f5f5;
  color: #1b1b1b;
  border: 1rpx solid #1b1b1b;
}

.tag:active {
  transform: scale(0.93);
}

/* === 保存栏 === */
.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1rpx solid #e5e5e5;
  z-index: 200;
}

.save-btn {
  height: 96rpx;
  background: #1b1b1b;
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 0;
}

.save-btn:active {
  background: #333;
  transform: scale(0.97);
}

.save-btn.saving {
  background: #999;
  pointer-events: none;
}
