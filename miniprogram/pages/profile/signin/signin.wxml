<!-- miniprogram/pages/signin/signin.wxml -->
<view class="signin-page">

  <!-- 连续签到大字 -->
  <view class="streak-display">
    <view class="streak-number">{{streakDays}}</view>
    <view class="streak-unit">连续签到</view>
    <view class="streak-hint">每日签到，记录坚持的力量</view>
  </view>

  <view class="divider"></view>

  <!-- 今日签到 -->
  <view class="today-section">
    <view class="section-label">TODAY</view>
    <view class="today-row">
      <view class="today-date-wrap">
        <view class="today-date-main">{{todayText}}</view>
        <view class="today-weekday">{{todayWeekday}}</view>
      </view>
      <view class="today-status" wx:if="{{signedToday}}">今日已签到</view>
    </view>
    <button class="checkin-btn {{signedToday ? 'signed' : ''}}" bindtap="onCheckinTap" disabled="{{signedToday}}">
      {{signedToday ? '已签到' : '立即签到'}}
    </button>
  </view>

  <view class="divider"></view>

  <!-- 本周 -->
  <view class="week-section">
    <view class="section-label">THIS WEEK</view>
    <view class="week-grid">
      <view class="week-item {{item.signed ? 'checked' : ''}} {{item.isToday ? 'today' : ''}} {{item.isFuture ? 'future' : ''}}"
            wx:for="{{weekDays}}" wx:key="date">
        <view class="week-dot">{{item.signed ? '✓' : item.dayNum}}</view>
        <view class="week-day-label">{{item.dayLabel}}</view>
      </view>
    </view>
  </view>

  <!-- 积分余额 -->
  <view class="credits-section">
    <view class="section-label">MY CREDITS</view>
    <view class="credits-card">
      <view class="credits-header">
        <view class="credits-title">剩余次数</view>
        <view class="credits-value-wrap">
          <view class="credits-value">{{credits}}</view>
          <view class="credits-unit">次</view>
        </view>
      </view>
    </view>
    <view class="credits-bonus-tip">
      <text wx:if="{{streakDays >= 7}}">已解锁连续7天 +2次奖励</text>
      <text wx:elif="{{streakDays >= 4}}">已解锁连续4天 +1次奖励</text>
      <text wx:else>连续签到4天额外+1次，7天额外+2次</text>
    </view>
  </view>

  <!-- 底部 -->
  <view class="footer">
    <view class="footer-note">坚持签到，让记忆更有重量</view>
    <view class="footer-note">邀请好友可获得补签卡</view>
  </view>

</view>