/* pages/settings/settings.wxss */

/* === 页面容器 === */
.settings-page {
  min-height: 100vh;
  background: #f8f8f8;
}

/* === 页面内容 === */
.page-body {
  padding: 32rpx 0 200rpx;
}

/* === 分组标题 === */
.section-title {
  font-size: 26rpx;
  color: #bbb;
  padding: 24rpx 16rpx 16rpx;
  font-weight: 400;
}

/* === 设置卡片 === */
.settings-card {
  background: #ffffff;
  border-radius: 0;
  overflow: hidden;
  margin: 0;
}

/* === 设置项 === */
.item {
  display: flex;
  align-items: center;
  padding: 14rpx 32rpx;
  min-height: 104rpx;
  position: relative;
}

.item:active {
  background: #f5f5f5;
}

/* 分隔线：从图标右侧到箭头左侧 */
.item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 112rpx;
  right: 32rpx;
  height: 1rpx;
  background: #f0f0f0;
}

.item:last-child::after {
  display: none;
}

/* === 图标 === */
.item-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-icon image {
  width: 40rpx;
  height: 40rpx;
}

/* === 文字 === */
.item-text {
  flex: 1;
  font-size: 30rpx;
  color: #1b1b1b;
  white-space: nowrap;
  line-height: 1;
}

/* === 副标题/状态值 === */
.item-value {
  font-size: 28rpx;
  color: #888;
  margin-right: 12rpx;
}

/* === 箭头 === */
.item-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

/* === 退出登录 === */
.logout-btn {
  display: block;
  width: calc(100% - 24rpx);
  margin: 84rpx 12rpx 0;
  height: 96rpx;
  background: #ffffff;
  border: none;
  border-radius: 48rpx;
  font-size: 30rpx;
  color: #ff4444;
  font-weight: 500;
  font-family: inherit;
  line-height: 96rpx;
  padding: 0 64rpx;
  box-sizing: border-box;
  text-align: center;
}

.logout-btn:active {
  background: #fff0f0;
}

.logout-btn::after {
  border: none;
}

/* === 版本栏 === */
.version-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
}

.version-text {
  font-size: 24rpx;
  color: #bbb;
}
