.bottom-bar {
  flex-shrink: 0;
  background: #fff;
  padding: 12rpx 24rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
  opacity: 0;
  transform: translateY(8rpx);
  transition: opacity 200ms ease, transform 200ms ease;
  z-index: 10;
}

.bottom-bar--show {
  opacity: 1;
  transform: translateY(0);
}

.input-area {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 20rpx;
  background: #f4f4f4;
  border-radius: 44rpx;
}

.input-pen-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.72;
  flex-shrink: 0;
  background: transparent;
}

.input-placeholder {
  font-size: 28rpx;
  color: #666;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  flex-shrink: 0;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  min-width: 72rpx;
}

.action-icon-img {
  width: 52rpx;
  height: 52rpx;
}

.action-num {
  font-size: 22rpx;
  color: #1b1b1b;
  font-weight: 500;
}

.action-num.liked {
  color: #fe2c55;
}
