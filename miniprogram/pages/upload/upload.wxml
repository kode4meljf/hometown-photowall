<!-- pages/upload/upload.wxml -->
<wxs src="../../utils/filters.wxs" module="filters" />

<view class="upload-page">
  <!-- 顶部大图预览区 -->
  <view class="preview-area">
    <swiper
      wx:if="{{imageList.length > 0}}"
      class="preview-swiper"
      current="{{currentIndex}}"
      bindchange="onSwiperChange"
    >
      <swiper-item wx:for="{{imageList}}" wx:key="index">
        <view class="preview-clip">
          <image
            class="preview-image"
            src="{{item}}"
            mode="scaleToFill"
            style="{{filters.imageStyle(imageInfoList[index].width, imageInfoList[index].height)}}"
            bindtap="previewFullScreen"
          />
          <!-- 封面操作覆盖层 -->
          <view class="cover-overlay" wx:if="{{imageList.length > 1}}">
            <view class="cover-btn-area" wx:if="{{index !== 0}}" catchtap="setAsCover" data-index="{{index}}">
              <text class="cover-btn-text">⭐ 设为封面</text>
            </view>
            <view class="cover-current-area" wx:if="{{index === 0}}">
              <text class="cover-current-text">当前封面</text>
            </view>
          </view>
        </view>
      </swiper-item>
    </swiper>
    <view wx:if="{{imageList.length === 0}}" class="preview-placeholder">
      <image class="placeholder-icon" src="/assets/icons/empty-photos.png" mode="aspectFit" />
      <text class="placeholder-text">点击下方添加图片</text>
    </view>
    <!-- 删除按钮 -->
    <view class="preview-delete-btn" wx:if="{{imageList.length > 0}}" catchtap="deleteCurrentImage">×</view>
    <!-- 计数器 -->
    <view class="image-counter" wx:if="{{imageList.length > 1}}">
      <text>{{currentIndex + 1}}/{{imageList.length}}</text>
    </view>
  </view>

  <!-- 缩略图栏：整体居中，溢出时缩略图滚、按钮靠右固定 -->
  <view class="thumbnail-bar {{isOverflow ? 'has-overflow' : ''}}">
    <view class="thumbnail-wrapper">
      <scroll-view
        class="thumbnail-scroll {{isOverflow ? 'has-overflow' : ''}}"
        scroll-x
        scroll-into-view="thumb-{{currentIndex}}"
        scroll-with-animation
      >
        <view class="thumbnail-row">
          <view
            id="thumb-{{index}}"
            class="thumbnail-item {{currentIndex === index ? 'selected' : ''}}"
            wx:for="{{imageList}}"
            wx:key="index"
            bindtap="selectImage"
            data-index="{{index}}"
          >
            <image class="thumbnail-image" src="{{item}}" mode="aspectFill" />
            <!-- 封面标签：仅第一张显示 -->
            <view class="cover-tag" wx:if="{{index === 0 && imageList.length > 1}}">
              <text class="cover-tag-text">封面</text>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="thumbnail-add" bindtap="chooseImage">
        <text class="add-icon">+</text>
      </view>
    </view>
  </view>

  <!-- 表单区域 -->
  <scroll-view class="form-scroll" scroll-y>
    <view class="form-section">
      <!-- 标题/描述 -->
      <view class="form-item">
        <input
          class="title-input {{highlightTitle ? 'highlight' : ''}}"
          placeholder="添加标题（选填）"
          placeholder-class="placeholder"
          value="{{form.title}}"
          bindinput="onTitleInput"
          focus="{{focusTitle}}"
        />
      </view>

      <view class="form-item">
        <textarea
          class="desc-input"
          placeholder="添加作品描述…"
          placeholder-class="placeholder"
          value="{{form.description}}"
          bindinput="onDescInput"
          maxlength="200"
        />
      </view>

      <!-- 地点选择 -->
      <view class="location-section">
        <!-- 标题行：图标+文字 + 选中tag（选中时显示在右侧） -->
        <view class="location-header {{form.location ? 'has-location' : ''}}">
          <image class="location-icon" src="/assets/icons/location.png" mode="aspectFit" />
          <text class="location-label">{{form.location || '你在哪里'}}</text>
          <!-- X 清除按钮：选中后靠屏幕最右 -->
          <view class="location-clear-btn" wx:if="{{form.location}}" bindtap="clearLocation">×</view>
        </view>
        <!-- 可选地点列表（未选中时显示） -->
        <view class="location-tags" wx:if="{{!form.location}}">
          <!-- 预置地点 -->
          <view
            class="location-tag"
            bindtap="selectLocation"
            data-location="老根茶"
          >
            <text>老根茶</text>
          </view>
          <!-- 动态地点（数据库已有，排除预置的「老根茶」） -->
          <view
            class="location-tag"
            wx:for="{{locations}}"
            wx:key="index"
            wx:if="{{item !== '老根茶'}}"
            bindtap="selectLocation"
            data-location="{{item}}"
          >
            <text>{{item}}</text>
          </view>
          <!-- 自定义地点输入 -->
          <input
            class="custom-location-input"
            placeholder="自定义"
            placeholder-class="placeholder"
            value="{{customLocation}}"
            bindinput="onCustomLocationInput"
            bindconfirm="confirmCustomLocation"
          />
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部发布按钮 -->
  <view class="submit-bar">
    <view class="submit-btn {{submitting ? 'submitting' : ''}}" bindtap="handleSubmit">
      <image class="submit-icon" src="/assets/icons/camera-empty.png" mode="aspectFit" wx:if="{{!submitting}}" />
      <text>{{submitting ? '发布中…' : '发布照片'}}</text>
    </view>
  </view>
</view>
