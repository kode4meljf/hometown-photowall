<view class="tabbar">
  <view
    wx:for="{{list}}"
    wx:key="text"
    class="tabbar-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <!-- 中间发布按钮：凸起圆形 -->
    <block wx:if="{{index === 1}}">
      <view class="publish-wrapper">
        <view class="publish-btn">
          <text class="publish-icon">+</text>
        </view>
      </view>
    </block>
    <!-- 两侧普通 tab -->
    <block wx:else>
      <image
        class="tabbar-icon"
        src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
        mode="aspectFit"
      />
      <text class="tabbar-text">{{item.text}}</text>
    </block>
  </view>
</view>
