/* pages/profile/signin/signin.wxss - v4 卡片风格 */

.signin-page {
  min-height: 100vh;
  background: #f8f8f8;
  padding: 24rpx 24rpx 80rpx;
  box-sizing: border-box;
}

/* Hero 卡片 */
.hero-card {
  background: #ffffff;
  border-radius: 40rpx;
  padding: 56rpx 48rpx 48rpx;
  text-align: center;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.hero-label {
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: #b0b0b0;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.streak-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.streak-number {
  font-size: 144rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: -6rpx;
  color: #1b1b1b;
}

.streak-unit {
  font-size: 32rpx;
  color: #888;
  font-weight: 500;
}

.streak-hint {
  font-size: 26rpx;
  color: #b0b0b0;
  margin-bottom: 40rpx;
}

.streak-progress {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.progress-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.progress-dot.done {
  background: #1b1b1b;
}

.progress-dot.current {
  background: #1b1b1b;
  box-shadow: 0 0 0 6rpx rgba(27, 27, 27, 0.12);
}

.progress-caption {
  font-size: 22rpx;
  color: #b0b0b0;
  margin-top: 16rpx;
}

/* 通用卡片 */
.section-card {
  background: #ffffff;
  border-radius: 40rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.section-label {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #b0b0b0;
  text-transform: uppercase;
  font-weight: 500;
}

.section-badge {
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
}

/* 今日 */
.today-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.today-date-main {
  font-size: 44rpx;
  font-weight: 600;
  color: #1b1b1b;
  line-height: 1.2;
}

.today-weekday {
  font-size: 26rpx;
  color: #b0b0b0;
  margin-top: 8rpx;
}

.today-reward {
  text-align: right;
}

.today-reward-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #1b1b1b;
}

.today-reward-label {
  font-size: 22rpx;
  color: #b0b0b0;
  margin-top: 4rpx;
}

.checkin-btn {
  width: 100%;
  height: 96rpx;
  background: #1b1b1b;
  border: none;
  border-radius: 48rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-btn::after {
  border: none;
}

.checkin-btn.signed {
  background: #fafafa;
  color: #b0b0b0;
  border: 2rpx solid #f0f0f0;
}

.checkin-btn-skeleton {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: signin-skeleton 1.2s ease-in-out infinite;
}

@keyframes signin-skeleton {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

/* 本周 */
.week-grid {
  display: flex;
  gap: 12rpx;
}

.week-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.week-dot {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fafafa;
  border: 2rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #b0b0b0;
  font-weight: 500;
}

.week-item.checked .week-dot {
  background: #1b1b1b;
  color: #fff;
  border-color: #1b1b1b;
}

.week-item.today .week-dot {
  border: 4rpx solid #1b1b1b;
  background: #fff;
  color: #1b1b1b;
  font-weight: 600;
}

.week-item.checked.today .week-dot {
  background: #1b1b1b;
  color: #fff;
  border-color: #1b1b1b;
}

.week-item.future .week-dot {
  color: #ddd;
  background: #fafafa;
  border-color: #f0f0f0;
}

.week-day-label {
  font-size: 20rpx;
  color: #b0b0b0;
}

/* 积分 */
.credits-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0 32rpx;
}

.credits-title {
  font-size: 28rpx;
  color: #888;
}

.credits-value-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.credits-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #1b1b1b;
  line-height: 1;
}

.credits-unit {
  font-size: 26rpx;
  color: #b0b0b0;
}

.credits-divider {
  height: 2rpx;
  background: #f0f0f0;
  margin-bottom: 28rpx;
}

.bonus-title {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 20rpx;
}

.bonus-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.bonus-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.bonus-tag.active {
  background: #fff8e8;
  color: #c8800a;
}

.bonus-tag.inactive {
  background: #fafafa;
  color: #ccc;
}

.bonus-tag .dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

/* 规则 */
.rules-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.rules-title {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.rules-item {
  font-size: 24rpx;
  color: #b0b0b0;
  line-height: 1.6;
  padding-left: 24rpx;
  position: relative;
  margin-bottom: 12rpx;
}

.rules-item:last-child {
  margin-bottom: 0;
}

.rules-item::before {
  content: '·';
  position: absolute;
  left: 0;
  color: #b0b0b0;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 16rpx 32rpx 48rpx;
}

.footer-note {
  font-size: 22rpx;
  color: #b0b0b0;
  line-height: 2;
  letter-spacing: 1rpx;
}
