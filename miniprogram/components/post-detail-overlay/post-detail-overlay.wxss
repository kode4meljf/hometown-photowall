.overlay-root {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: var(--z-detail-overlay);
  padding-top: 0;
}

.overlay-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  transition: background 300ms cubic-bezier(0.25, 0.1, 0.25, 1);
}

.overlay-mask.mask-visible {
  /* 实际颜色由 maskStyle 内联控制，此处仅保留过渡 */
}

.overlay-mask.mask-no-transition {
  transition: none;
}

.detail-panel {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  display: flex;
  flex-direction: column;
  background: transparent;
  opacity: 0;
  pointer-events: none;
  transition: opacity 160ms ease;
  transform-origin: center center;
  will-change: transform, border-radius;
  overflow: hidden;
  isolation: isolate;
}

.detail-panel.panel-show.detail-panel-ready {
  z-index: 3;
  background: #f7f7f7;
  opacity: 1;
  pointer-events: auto;
  transition: opacity 140ms ease;
}

.detail-panel.panel-show.detail-panel-ready.shell-scaling {
  will-change: transform;
}

.detail-panel.panel-exiting {
  overflow: hidden;
  border-radius: 24rpx;
  background: #fff;
}

.panel-exit-chrome {
  opacity: 0 !important;
  max-height: 0 !important;
  overflow: hidden !important;
  pointer-events: none !important;
  margin: 0 !important;
  padding-top: 0 !important;
  padding-bottom: 0 !important;
  border: none !important;
  transition: opacity 80ms ease, max-height 80ms ease;
}

.panel-header.panel-exit-chrome {
  height: 0 !important;
  min-height: 0 !important;
}

.bottom-bar.panel-exit-chrome {
  height: 0 !important;
  min-height: 0 !important;
}

.detail-panel.panel-dragging {
  transition: opacity 120ms ease;
  box-shadow: 0 16rpx 80rpx rgba(0, 0, 0, 0.22);
}

.panel-header {
  flex-shrink: 0;
  box-sizing: border-box;
  background: #fff;
  padding-left: 16rpx;
  padding-bottom: 6rpx;
  display: flex;
  align-items: flex-end;
  border-bottom: 1rpx solid #f0f0f0;
  z-index: 1004;
}

.panel-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
  box-sizing: border-box;
}

.back-btn {
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -4rpx;
}

.back-btn text {
  font-size: 56rpx;
  font-weight: 400;
  line-height: 1;
  color: #1b1b1b;
}

.author-avatar {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #f0f0f0;
}

.author-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1b1b1b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-media-wrap {
  position: fixed;
  z-index: 1006;
  transform-origin: left top;
  will-change: transform, opacity;
  pointer-events: none;
  overflow: hidden;
}

.hero-media-img {
  width: 100%;
  height: 100%;
  display: block;
}

.hero-dim {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: #000;
  pointer-events: none;
}

.hero-media-wrap.hero-transition {
  transition: transform 300ms cubic-bezier(0.25, 0.1, 0.25, 1),
              opacity 300ms cubic-bezier(0.25, 0.1, 0.25, 1);
}

.hero-media-wrap.hero-transition .hero-dim {
  transition: opacity 300ms cubic-bezier(0.25, 0.1, 0.25, 1);
}

.hero-media-wrap.hero-fade-out {
  transition: opacity 120ms ease;
}

.hero-media-wrap.hero-fade-out .hero-dim {
  transition: opacity 120ms ease;
}

.fly-title {
  position: fixed;
  z-index: 1005;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  font-size: 26rpx;
  line-height: 1.4;
  color: #444;
  background: transparent;
  box-sizing: border-box;
  pointer-events: none;
}

.card-title {
  color: #444;
  font-weight: 500;
}

.card-desc {
  color: #666;
}

.panel-scroll {
  flex: 1;
  height: 0;
}

.image-section {
  width: 100%;
  overflow: hidden;
  position: relative;
}

.image-section.image-slot--stage {
  background: #0d0d0d;
}

.slot-media {
  position: absolute;
  z-index: 2;
  pointer-events: none;
  opacity: 0;
}

.slot-media.slot-media--show {
  opacity: 1;
  transition: opacity 100ms ease;
}

.media-skeleton {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
  pointer-events: none;
}

.progress-bar--skeleton {
  z-index: 4;
}

.panel-photo-wrap {
  position: relative;
  z-index: 4;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.panel-photo-wrap.swiper-show {
  pointer-events: auto;
  transition: opacity 120ms ease;
}

.panel-photo-wrap.photo-letterbox {
  background: #fff;
}

.panel-photo-wrap.swiper-crossfade {
  transition: opacity 120ms ease;
}


.photo-swiper,
.photo-swiper .photo-image {
  width: 100%;
  height: 100%;
}

.photo-swiper .photo-image {
  object-fit: contain;
}

.progress-bar {
  position: absolute;
  bottom: 10rpx;
  left: 0;
  right: 0;
  display: flex;
  gap: 4px;
  padding: 0 24rpx;
  pointer-events: none;
  z-index: 3;
}

.progress-segment {
  flex: 1;
  height: 3px;
  border-radius: 1.5px;
  transition: background 0.3s ease;
}

.progress-segment.done {
  background: rgba(255, 255, 255, 0.85);
}

.progress-segment.todo {
  background: rgba(255, 255, 255, 0.15);
}

.photo-index-badge {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  background: rgba(0, 0, 0, 0.35);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: 3;
}

.photo-index-badge.badge-show {
  opacity: 1;
}

.badge-text {
  font-size: 24rpx;
  color: #fff;
}

.content-section {
  padding: 24rpx;
  background: #fff;
}

.title-slot {
  min-height: 44px;
}

/* 动画测量用，不展示（避免与 fly-title、正文区重复） */
.title-slot--measure {
  opacity: 0;
  pointer-events: none;
}

.description {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.date {
  font-size: 26rpx;
  color: #999;
}

.divider {
  height: 16rpx;
  background: #f8f8f8;
}

.content-reveal {
  opacity: 0;
  transform: translateY(12rpx);
  transition: opacity 280ms ease, transform 280ms ease;
}

.content-reveal.show {
  opacity: 1;
  transform: translateY(0);
}

.panel-loading {
  padding: 48rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.overlay-login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: var(--z-detail-login);
  pointer-events: none;
}

.share-poster-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 750px;
  height: 1180px;
  opacity: 0;
  pointer-events: none;
}

.share-poster-mask {
  position: fixed;
  inset: 0;
  z-index: var(--z-detail-login);
  background: rgba(0, 0, 0, 0.88);
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-poster-backdrop {
  width: 100%;
  padding: 48rpx 56rpx calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.share-poster-close {
  position: absolute;
  top: 0;
  right: 48rpx;
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.85);
}

.share-poster-preview {
  width: 480rpx;
  border-radius: 24rpx;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.45);
}

.share-poster-save {
  margin-top: 40rpx;
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  padding: 20rpx 64rpx;
  border-radius: 44rpx;
}
