.report-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: var(--z-detail-preview);
}

.report-modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
}

.report-modal-card {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  max-width: 86%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 0;
  box-sizing: border-box;
}

.report-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  color: #1b1b1b;
}

.report-modal-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
  line-height: 1.55;
}

.report-modal-reason {
  margin-top: 24rpx;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.report-modal-textarea {
  width: 100%;
  height: 160rpx;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1b1b1b;
  box-sizing: border-box;
}

.report-modal-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 28rpx;
}

.report-modal-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.report-modal-btn-cancel {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.report-modal-btn-submit {
  color: #576b95;
  font-weight: 600;
}

.report-modal-btn-submit.disabled {
  opacity: 0.5;
}
